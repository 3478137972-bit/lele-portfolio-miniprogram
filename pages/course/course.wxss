/* pages/course/course.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  display: block;
}

/* 课程介绍 */
.intro {
  margin-bottom: 30rpx;
}

.intro-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  text-align: center;
  display: block;
}

/* 模块卡片 */
.modules {
  margin-bottom: 30rpx;
}

.module-card {
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.module-card:last-child {
  margin-bottom: 0;
}

.module-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.module-number {
  font-size: 48rpx;
  font-weight: bold;
  color: rgba(249, 115, 22, 0.2);
  line-height: 1;
}

.module-icon {
  font-size: 48rpx;
}

.module-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 20rpx;
}

.module-content {
  background: #f9fafb;
  padding: 24rpx;
  border-radius: 12rpx;
}

.module-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 2;
  display: block;
}

/* 报名区域 */
.enroll {
  text-align: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 30rpx;
  display: block;
}

/* 二维码 */
.qrcode-section {
  margin-bottom: 30rpx;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 16rpx;
}

.qrcode-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
}

/* 联系信息 */
.contact-info {
  margin-bottom: 30rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
}

.contact-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary,
.btn-secondary {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #F97316;
  border: 2rpx solid #F97316;
}
