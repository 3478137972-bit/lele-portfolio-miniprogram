/* pages/course/course.wxss - 课程列表页（重新设计版） */

/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F97316 0%, #FB923C 100%);
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 页面标题 */
.header {
  text-align: center;
  padding: 40rpx 0;
  color: #ffffff;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
}

/* 课程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 课程卡片 */
.course-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s;
}

.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

/* 特色卡片（AI 实战营） */
.course-card.featured {
  background: linear-gradient(135deg, #FFF7ED 0%, #FFFFFF 100%);
  border: 3rpx solid #F97316;
}

/* 卡片头部 */
.course-header {
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.course-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.course-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
}

/* 课程标签 */
.course-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  width: fit-content;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.3);
}

.course-tag.free {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.course-tag.deposit {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.3);
}

/* 课程统计 */
.course-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #6b7280;
}

.price-tag {
  font-size: 28rpx;
  font-weight: 700;
  color: #F97316;
}

/* 课程描述 */
.course-desc {
  display: block;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  background: #f9fafb;
}

/* 卡片底部 */
.course-footer {
  padding: 20rpx 32rpx;
  text-align: right;
  background: linear-gradient(90deg, transparent 0%, rgba(249, 115, 22, 0.05) 100%);
}

.course-action {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 600;
  color: #F97316;
  position: relative;
  padding-right: 40rpx;
}

.course-action::after {
  content: '→';
  position: absolute;
  right: 10rpx;
  transition: transform 0.3s;
}

.course-card:active .course-action::after {
  transform: translateX(8rpx);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #ffffff;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 28rpx;
  opacity: 0.9;
}
