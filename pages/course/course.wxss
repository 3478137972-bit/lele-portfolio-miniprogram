/* pages/course/course.wxss - 课程列表页 */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  display: block;
}

/* 课程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 课程卡片 */
.course-card {
  position: relative;
  overflow: hidden;
}

.course-card:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.course-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.course-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.course-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.course-tag {
  font-size: 24rpx;
  color: #fff;
  background: #F97316;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.course-tag.free {
  background: #10b981;
}

.course-tag.deposit {
  background: #8b5cf6;
}

.course-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.course-footer {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.course-action {
  font-size: 26rpx;
  color: #F97316;
  font-weight: 600;
}
