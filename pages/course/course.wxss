/* pages/course/course.wxss - 课程列表页（组件化 + 动效版） */

/* ===== 容器与布局 ===== */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ===== 顶部横幅 ===== */
.hero-banner {
  position: relative;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 50%, #F97316 100%);
  background-size: 200% 200%;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
  animation: gradientFlow 8s ease infinite;
}

@keyframes gradientFlow {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 装饰元素 */
.hero-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  animation: float 6s ease-in-out infinite;
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
  animation-delay: 0s;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  bottom: 40rpx;
  left: -30rpx;
  animation-delay: 2s;
}

.circle-3 {
  width: 80rpx;
  height: 80rpx;
  top: 40rpx;
  left: 20%;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(180deg); }
}

/* ===== 课程区块 ===== */
.course-section {
  margin-top: 32rpx;
  padding: 0 24rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 课程列表 ===== */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 课程卡片 ===== */
.course-card {
  position: relative;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: cardSlideUp 0.6s ease-out both;
}

@keyframes cardSlideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.course-card.featured {
  border: 3rpx solid #F97316;
  box-shadow: 0 12rpx 48rpx rgba(249, 115, 22, 0.2);
}

/* 顶部装饰条 */
.card-top-bar {
  height: 8rpx;
  width: 100%;
  transition: height 0.3s ease;
}

.course-card:active .card-top-bar {
  height: 12rpx;
}

/* 卡片内容 */
.card-content {
  padding: 32rpx 32rpx 24rpx;
}

/* 图标区域 */
.card-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.course-card:active .card-icon-wrapper {
  transform: scale(0.9);
}

.card-icon {
  font-size: 48rpx;
  font-weight: 700;
}

/* 标签 */
.card-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.25);
  animation: tagPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55) both;
  animation-delay: 0.3s;
}

@keyframes tagPop {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.tag.default {
  background: linear-gradient(135deg, #6B7280 0%, #9CA3AF 100%);
  box-shadow: 0 4rpx 12rpx rgba(107, 114, 128, 0.25);
}

.tag.success {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.25);
}

.tag.purple {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.25);
}

/* 标题 */
.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
  line-height: 1.4;
  transition: color 0.3s ease;
}

.course-card:active .card-title {
  color: #F97316;
}

/* 描述 */
.card-desc {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

/* 统计信息 */
.card-stats {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.stat-icon {
  font-size: 24rpx;
  color: #9ca3af;
}

.stat-text {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 卡片底部 */
.card-footer {
  padding: 20rpx 32rpx 28rpx;
  border-top: 2rpx solid #f3f4f6;
  background: linear-gradient(90deg, transparent 0%, rgba(249, 115, 22, 0.03) 100%);
}

.card-action {
  display: inline-flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #F97316;
  transition: all 0.3s ease;
}

.action-arrow {
  margin-left: 8rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.course-card:active .card-action .action-arrow {
  transform: translateX(8rpx);
}

/* ===== 加载动画 ===== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f4f6;
  border-top-color: #F97316;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #6b7280;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}
