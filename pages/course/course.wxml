<!--pages/course/course.wxml-->
<view class="container">
  <!-- 课程标题 -->
  <view class="header">
    <text class="title">AI 实战营</text>
    <text class="subtitle">用 AI 赋能你的业务增长</text>
  </view>

  <!-- 课程介绍 -->
  <view class="intro card">
    <text class="intro-text">
      系统学习 AI 在设计、产品、运营中的实战应用
      让你轻松掌握 AI 工具，提升工作效率
    </text>
  </view>

  <!-- 4 大模块 -->
  <view class="modules">
    <view class="module-card card" wx:for="{{modules}}" wx:key="index">
      <view class="module-header">
        <text class="module-number">{{item.number}}</text>
        <text class="module-icon">{{item.icon}}</text>
      </view>
      <text class="module-title">{{item.title}}</text>
      <view class="module-content">
        <text class="module-desc" wx:for="{{item.points}}" wx:key="index" wx:for-item="point">
          • {{point}}
        </text>
      </view>
    </view>
  </view>

  <!-- 报名方式 -->
  <view class="enroll card">
    <text class="section-title">报名方式</text>
    
    <!-- 二维码 -->
    <view class="qrcode-section">
      <image 
        class="qrcode" 
        src="/static/images/qrcode/wechat.jpg" 
        mode="aspectFill"
        bindtap="previewQrcode"
      />
      <text class="qrcode-hint">长按识别二维码添加微信</text>
    </view>

    <!-- 联系方式 -->
    <view class="contact-info">
      <view class="contact-item">
        <text class="contact-icon">💬</text>
        <text class="contact-text">微信：{{wechat}}</text>
      </view>
      <view class="contact-item">
        <text class="contact-icon">📧</text>
        <text class="contact-text">邮箱：{{email}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn-primary" bindtap="copyWechat">
        复制微信号
      </button>
      <button class="btn-secondary" open-type="share">
        分享给朋友
      </button>
    </view>
  </view>
</view>
