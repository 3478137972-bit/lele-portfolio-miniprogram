<!-- pages/course/course.wxml - 课程列表页（组件化 + 动效版） -->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="hero-banner">
    <view class="hero-content">
      <text class="hero-title">课程与活动</text>
      <text class="hero-subtitle">找到适合你的成长路径</text>
    </view>
    <view class="hero-decoration">
      <view class="deco-circle circle-1"></view>
      <view class="deco-circle circle-2"></view>
      <view class="deco-circle circle-3"></view>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="course-section">
    <view class="section-header">
      <text class="section-title">全部课程</text>
      <text class="section-count">{{courses.length}} 个课程</text>
    </view>

    <view class="course-list">
      <view 
        class="course-card card-hover {{item.featured ? 'featured' : ''}}" 
        wx:for="{{courses}}" 
        wx:key="id"
        bindtap="onCourseTap"
        data-course="{{item}}"
        style="animation-delay: {{index * 0.1}}s"
      >
        <!-- 卡片顶部装饰条 -->
        <view class="card-top-bar" style="background: {{item.color}}"></view>
        
        <!-- 卡片内容 -->
        <view class="card-content">
          <!-- 图标区域 -->
          <view class="card-icon-wrapper" style="background: {{item.color}}20">
            <text class="card-icon" style="color: {{item.color}}">{{item.icon}}</text>
          </view>
          
          <!-- 标签 -->
          <view class="card-tags" wx:if="{{item.tags && item.tags.length}}">
            <text 
              class="tag tag-{{item.tagType || 'default'}}" 
              wx:for="{{item.tags}}" 
              wx:key="*this"
              wx:for-item="tag"
            >{{tag}}</text>
          </view>
          
          <!-- 标题 -->
          <text class="card-title">{{item.title}}</text>
          
          <!-- 描述 -->
          <text class="card-desc">{{item.description}}</text>
          
          <!-- 统计信息 -->
          <view class="card-stats">
            <view class="stat-item" wx:if="{{item.students}}">
              <text class="stat-icon icon-users"></text>
              <text class="stat-text">{{item.students}}</text>
            </view>
            <view class="stat-item" wx:if="{{item.duration}}">
              <text class="stat-icon icon-clock"></text>
              <text class="stat-text">{{item.duration}}</text>
            </view>
            <view class="stat-item" wx:if="{{item.schedule}}">
              <text class="stat-icon icon-calendar"></text>
              <text class="stat-text">{{item.schedule}}</text>
            </view>
          </view>
        </view>
        
        <!-- 卡片底部 -->
        <view class="card-footer">
          <text class="card-action">
            查看详情
            <text class="action-arrow">→</text>
          </text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 加载动画 -->
<view class="loading-overlay" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>
