<!--pages/course/course.wxml - 课程列表页-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">课程与活动</text>
    <text class="subtitle">找到适合你的成长路径</text>
  </view>

  <!-- 课程列表 -->
  <view class="course-list">
    
    <!-- AI 实战营 -->
    <view class="course-card card" bindtap="goToCourseDetail" data-course="ai-bootcamp">
      <view class="course-header">
        <text class="course-icon">🚀</text>
        <view class="course-info">
          <text class="course-name">AI 实战营</text>
          <text class="course-tag">共创项目</text>
        </view>
      </view>
      <text class="course-desc">系统学习 AI 在设计、产品、运营中的实战应用</text>
      <view class="course-footer">
        <text class="course-action">查看详情 →</text>
      </view>
    </view>

    <!-- 大学线下分享 -->
    <view class="course-card card" bindtap="goToCourseDetail" data-course="university-share">
      <view class="course-header">
        <text class="course-icon">🎓</text>
        <view class="course-info">
          <text class="course-name">大学线下分享</text>
          <text class="course-tag free">免费参与</text>
        </view>
      </view>
      <text class="course-desc">走进高校，分享 AI 时代超级个体全链路打法</text>
      <view class="course-footer">
        <text class="course-action">查看详情 →</text>
      </view>
    </view>

    <!-- 初级 IP 运营课程 -->
    <view class="course-card card" bindtap="goToCourseDetail" data-course="ip-operation">
      <view class="course-header">
        <text class="course-icon">📱</text>
        <view class="course-info">
          <text class="course-name">初级 IP 运营课程</text>
          <text class="course-tag deposit">交押金·全勤全退</text>
        </view>
      </view>
      <text class="course-desc">以副业为切入点，打造个人 IP + 自媒体运营全攻略</text>
      <view class="course-footer">
        <text class="course-action">查看详情 →</text>
      </view>
    </view>

    <!-- AI 设计课程 -->
    <view class="course-card card" bindtap="goToCourseDetail" data-course="ai-design">
      <view class="course-header">
        <text class="course-icon">🎨</text>
        <view class="course-info">
          <text class="course-name">AI 设计课程</text>
          <text class="course-tag deposit">交押金·全勤全退</text>
        </view>
      </view>
      <text class="course-desc">全部内容经过落地检验，AI 完成度 90-99%</text>
      <view class="course-footer">
        <text class="course-action">查看详情 →</text>
      </view>
    </view>

  </view>
</view>
