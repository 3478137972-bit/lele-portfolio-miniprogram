<!--pages/portfolio/portfolio.wxml - 案例集（三级分类重构版）-->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="hero-banner">
    <view class="hero-content">
      <text class="hero-title">案例集</text>
      <text class="hero-subtitle">完整项目案例展示</text>
    </view>
  </view>

  <!-- 一级分类 -->
  <view class="category-section">
    <scroll-view class="category-scroll" scroll-x enable-flex>
      <view 
        class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="onCategoryTap"
        data-category="{{item.id}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-text">{{item.name}}</text>
        <view class="category-indicator" wx:if="{{currentCategory === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 二级品牌（仅品牌全案分类显示） -->
  <view class="brand-section" wx:if="{{currentCategory === 'brand' && brands[currentCategory].length > 0}}">
    <scroll-view class="brand-scroll" scroll-x enable-flex>
      <view 
        class="brand-item {{currentBrand === item.id ? 'active' : ''}}" 
        wx:for="{{brands[currentCategory]}}" 
        wx:key="id"
        bindtap="onBrandTap"
        data-brand="{{item.id}}"
      >
        <text class="brand-text">{{item.name}}</text>
        <view class="brand-indicator" wx:if="{{currentBrand === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 二级子分类（仅 AI 设计作品、AI 产品和运营相关案例显示） -->
  <view class="subcategory-section" wx:if="{{(currentCategory === 'ai_design' || currentCategory === 'ai_product' || currentCategory === 'operations') && subcategories[currentCategory].length > 0}}">
    <scroll-view class="subcategory-scroll" scroll-x enable-flex>
      <view 
        class="subcategory-item {{currentSubcategory === item.id ? 'active' : ''}}" 
        wx:for="{{subcategories[currentCategory]}}" 
        wx:key="id"
        bindtap="onSubcategoryTap"
        data-subcategory="{{item.id}}"
      >
        <text class="subcategory-text">{{item.name}}</text>
        <view class="subcategory-indicator" wx:if="{{currentSubcategory === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 作品网格 -->
  <view class="works-section">
    <view class="section-header">
      <text class="section-title">
        {{currentCategoryInfo.name}}
        <text class="section-brand" wx:if="{{currentBrandInfo}}">· {{currentBrandInfo.name}}</text>
        <text class="section-brand" wx:if="{{(currentCategory === 'ai_design' || currentCategory === 'ai_product' || currentCategory === 'operations') && currentSubcategoryInfo}}">· {{currentSubcategoryInfo.name}}</text>
      </text>
    </view>

    <!-- 左右滑动画廊（所有分类统一） -->
    <view class="carousel-gallery" wx:if="{{currentCategory !== 'ai_product' || (currentSubcategory !== 'ai_miniprogram' && currentSubcategory !== 'ai_sticker')}}">
      <!-- 大图展示区 -->
      <view class="carousel-main {{currentCategory === 'ai_design' && currentSubcategory === 'ai_sticker' ? 'sticker-ratio' : ''}}">
        <swiper 
          class="carousel-swiper"
          current="{{currentImageIndex}}"
          bindchange="onCarouselChange"
          circular
          autoplay="{{false}}"
        >
          <swiper-item wx:for="{{works}}" wx:key="index" data-index="{{index}}" bindtap="onWorkTap">
            <view class="carousel-item">
              <image 
                class="carousel-image" 
                src="{{item.image || item}}" 
                mode="aspectFit"
                lazy-load
              ></image>
              <view class="carousel-overlay">
                <text class="carousel-number">{{index + 1}} / {{works.length}}</text>
                <text class="carousel-title">{{currentBrandInfo.name || currentCategoryInfo.name}} · 作品 {{index + 1}}</text>
              </view>
            </view>
          </swiper-item>
        </swiper>
      </view>

      <!-- 底部小图导航（AI 表情包不显示） -->
      <view class="carousel-thumbs" wx:if="{{!(currentCategory === 'ai_design' && currentSubcategory === 'ai_sticker')}}">
        <scroll-view 
          class="thumbs-scroll" 
          scroll-x 
          scroll-into-view="thumb-{{currentImageIndex}}"
          scroll-with-animation
        >
          <view class="thumbs-wrapper">
            <view 
              class="thumb-item {{index === currentImageIndex ? 'active' : ''}}" 
              wx:for="{{works}}" 
              wx:key="index"
              id="thumb-{{index}}"
              bindtap="onThumbTap"
              data-index="{{index}}"
            >
              <image 
                class="thumb-image" 
                src="{{item.image || item}}" 
                mode="aspectFill"
              ></image>
              <view class="thumb-indicator" wx:if="{{index === currentImageIndex}}"></view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
    
    <!-- 9:16 竖版轮播图（AI 产品 -AI 小程序专用） -->
    <view class="poster-carousel" wx:if="{{currentCategory === 'ai_product' && currentSubcategory === 'ai_miniprogram'}}">
      <swiper class="poster-swiper" circular indicator-dots>
        <swiper-item wx:for="{{works}}" wx:key="index">
          <image src="{{item.image || item}}" mode="aspectFill" class="poster-image"/>
        </swiper-item>
      </swiper>
    </view>
    
    <!-- 1:1 方图展示（AI 设计作品 -AI 表情包专用） -->
    <view class="sticker-square-gallery" wx:if="{{currentCategory === 'ai_design' && currentSubcategory === 'ai_sticker'}}">
      <view class="sticker-grid">
        <view 
          class="sticker-item" 
          wx:for="{{works}}" 
          wx:key="index"
          bindtap="onWorkTap"
          data-index="{{index}}"
        >
          <image 
            class="sticker-image" 
            src="{{item.image || item}}" 
            mode="aspectFill"
            lazy-load
          ></image>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{works.length === 0}}">
      <text class="empty-icon">🎨</text>
      <text class="empty-text">暂无作品</text>
    </view>
  </view>
</view>

<!-- 图片预览 -->
<view class="preview-modal" wx:if="{{previewVisible}}" bindtap="closePreview">
  <view class="preview-content" catchtap="stopPropagation">
    <swiper 
      class="preview-swiper" 
      current="{{previewIndex}}" 
      indicator-dots
      indicator-active-color="#ffffff"
      indicator-color="rgba(255,255,255,0.5)"
      bindchange="onPreviewChange"
    >
      <swiper-item wx:for="{{works}}" wx:key="index">
        <image 
          class="preview-image" 
          src="{{item.image || item}}" 
          mode="aspectFit"
          bindtap="closePreview"
        ></image>
      </swiper-item>
    </swiper>
    
    <view class="preview-info">
      <text class="preview-counter">{{previewIndex + 1}} / {{works.length}}</text>
      <view class="preview-actions">
        <button class="preview-btn" open-type="share">分享</button>
        <button class="preview-btn" bindtap="onSaveImage">保存</button>
      </view>
    </view>
    
    <view class="preview-close" bindtap="closePreview">✕</view>
  </view>
</view>
