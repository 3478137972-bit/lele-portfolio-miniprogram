<!--pages/portfolio/portfolio.wxml - 案例集（三级分类重构版）-->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="hero-banner">
    <view class="hero-content">
      <text class="hero-title">案例集</text>
      <text class="hero-subtitle">完整项目案例展示</text>
    </view>
  </view>

  <!-- 一级分类 -->
  <view class="category-section">
    <scroll-view class="category-scroll" scroll-x enable-flex>
      <view 
        class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="onCategoryTap"
        data-category="{{item.id}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-text">{{item.name}}</text>
        <view class="category-indicator" wx:if="{{currentCategory === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 二级品牌（仅品牌全案分类显示） -->
  <view class="brand-section" wx:if="{{currentCategory === 'brand' && brands[currentCategory].length > 0}}">
    <scroll-view class="brand-scroll" scroll-x enable-flex>
      <view 
        class="brand-item {{currentBrand === item.id ? 'active' : ''}}" 
        wx:for="{{brands[currentCategory]}}" 
        wx:key="id"
        bindtap="onBrandTap"
        data-brand="{{item.id}}"
      >
        <text class="brand-text">{{item.name}}</text>
        <view class="brand-indicator" wx:if="{{currentBrand === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 二级子分类（仅 AI 设计作品、AI 产品和运营相关案例显示） -->
  <view class="subcategory-section" wx:if="{{(currentCategory === 'ai_design' || currentCategory === 'ai_product' || currentCategory === 'operations') && subcategories[currentCategory].length > 0}}">
    <scroll-view class="subcategory-scroll" scroll-x enable-flex>
      <view 
        class="subcategory-item {{currentSubcategory === item.id ? 'active' : ''}}" 
        wx:for="{{subcategories[currentCategory]}}" 
        wx:key="id"
        bindtap="onSubcategoryTap"
        data-subcategory="{{item.id}}"
      >
        <text class="subcategory-text">{{item.name}}</text>
        <view class="subcategory-indicator" wx:if="{{currentSubcategory === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 运营分类专用：橙色系可滑动折线图 -->
  <view class="chart-section" wx:if="{{currentCategory === 'operations' && currentSubcategory === 'self_media'}}">
    <view class="chart-header">
      <view class="chart-title">📈 粉丝增长趋势</view>
      <view class="chart-subtitle">从 0 到 2000 粉的成长之路</view>
    </view>
    
    <!-- 可横向滑动的图表容器 -->
    <scroll-view class="chart-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
      <view class="chart-scroll-content" style="width: {{chartWidth}}rpx;">
        <!-- 折线图 SVG -->
        <svg class="chart-svg" width="{{chartWidth}}" height="320">
          <defs>
            <!-- 橙色渐变填充 -->
            <linearGradient id="areaGradient" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" style="stop-color:#fa8c16;stop-opacity:0.4" />
              <stop offset="100%" style="stop-color:#fa8c16;stop-opacity:0.05" />
            </linearGradient>
            
            <!-- 橙色渐变线条 -->
            <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#faad14" />
              <stop offset="100%" style="stop-color:#fa8c16" />
            </linearGradient>
          </defs>
          
          <!-- 背景网格（横线） -->
          <line x1="60" y1="30" x2="{{chartWidth - 20}}" y2="30" stroke="#f5f5f5" stroke-width="1"/>
          <line x1="60" y1="90" x2="{{chartWidth - 20}}" y2="90" stroke="#f5f5f5" stroke-width="1"/>
          <line x1="60" y1="150" x2="{{chartWidth - 20}}" y2="150" stroke="#f5f5f5" stroke-width="1"/>
          <line x1="60" y1="210" x2="{{chartWidth - 20}}" y2="210" stroke="#f5f5f5" stroke-width="1"/>
          <line x1="60" y1="270" x2="{{chartWidth - 20}}" y2="270" stroke="#f5f5f5" stroke-width="1"/>
          
          <!-- 填充区域 -->
          <path 
            d="{{areaPath}}" 
            fill="url(#areaGradient)" 
            stroke="none"
          />
          
          <!-- 折线 -->
          <polyline 
            points="{{chartPoints}}" 
            fill="none" 
            stroke="url(#lineGradient)" 
            stroke-width="4" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          />
          
          <!-- 时间节点（大圆点） -->
          <g wx:for="{{chartData}}" wx:key="date" wx:for-index="index">
            <!-- 外圈光晕 -->
            <circle 
              cx="{{item.x}}" 
              cy="{{item.y}}" 
              r="16" 
              fill="{{selectedIndex === index ? 'rgba(250,140,22,0.3)' : 'rgba(250,140,22,0)'}}"
            />
            
            <!-- 主圆点 -->
            <circle 
              cx="{{item.x}}" 
              cy="{{item.y}}" 
              r="10" 
              fill="#fff"
              stroke="#fa8c16"
              stroke-width="3"
              data-index="{{index}}"
              bindtap="onChartPointTap"
              class="chart-point"
            />
            
            <!-- 中心点 -->
            <circle 
              cx="{{item.x}}" 
              cy="{{item.y}}" 
              r="4" 
              fill="#fa8c16"
            />
            
            <!-- 日期标签（显示在圆点下方） -->
            <text 
              x="{{item.x}}" 
              y="{{item.y + 35}}" 
              font-size="12" 
              fill="#999"
              text-anchor="middle"
            >{{item.month}}</text>
          </g>
        </svg>
        
        <!-- Y 轴标签 -->
        <view class="chart-y-axis">
          <text class="y-label">2000</text>
          <text class="y-label">1500</text>
          <text class="y-label">1000</text>
          <text class="y-label">500</text>
          <text class="y-label">0</text>
        </view>
      </view>
    </scroll-view>
    
    <!-- 点击详情卡片 -->
    <view class="detail-card" wx:if="{{selectedIndex !== null}}">
      <view class="detail-date">{{chartData[selectedIndex].date}}</view>
      <view class="detail-value">{{chartData[selectedIndex].followers}} 人</view>
      <view class="detail-label">{{chartData[selectedIndex].label}}</view>
    </view>
    
    <!-- 统计数据 -->
    <view class="chart-stats">
      <view class="stat-item">
        <view class="stat-label">总粉丝</view>
        <view class="stat-value">2000</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-label">增长</view>
        <view class="stat-value highlight">+2000</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-label">完成率</view>
        <view class="stat-value">100%</view>
      </view>
    </view>
    
    <!-- 提示 -->
    <view class="chart-hint">
      <text class="hint-icon">👈</text>
      <text class="hint-text">左右滑动查看更多</text>
    </view>
  </view>

  <!-- 作品网格 -->
  <view class="works-section">
    <view class="section-header">
      <text class="section-title">
        {{currentCategoryInfo.name}}
        <text class="section-brand" wx:if="{{currentBrandInfo}}">· {{currentBrandInfo.name}}</text>
        <text class="section-brand" wx:if="{{(currentCategory === 'ai_design' || currentCategory === 'ai_product' || currentCategory === 'operations') && currentSubcategoryInfo}}">· {{currentSubcategoryInfo.name}}</text>
      </text>
    </view>

    <!-- 运营分类：简化提示 -->
    <view class="operations-hint" wx:if="{{currentCategory === 'operations'}}">
      <text class="operations-hint-text">👆 点击上方卡片查看粉丝增长曲线</text>
    </view>
    
    <!-- 其他分类：轮播图 -->
    <view class="carousel-gallery" wx:if="{{currentCategory !== 'operations'}}">
      <!-- 大图展示区 -->
      <view class="carousel-main {{currentCategory === 'ai_design' && currentSubcategory === 'ai_sticker' ? 'sticker-ratio' : ''}} {{currentCategory === 'ai_design' && currentSubcategory === 'ai_promo_poster' ? 'poster-ratio' : ''}} {{currentCategory === 'ai_product' && currentSubcategory === 'ai_miniprogram' ? 'miniprogram-ratio' : ''}}">
        <swiper 
          class="carousel-swiper"
          current="{{currentImageIndex}}"
          bindchange="onCarouselChange"
          circular
          autoplay="{{false}}"
        >
          <swiper-item wx:for="{{works}}" wx:key="index" data-index="{{index}}" bindtap="onWorkTap">
            <view class="carousel-item">
              <image 
                class="carousel-image" 
                src="{{item.image || item}}" 
                mode="aspectFit"
                lazy-load
              ></image>
              <view class="carousel-overlay">
                <text class="carousel-number">{{index + 1}} / {{works.length}}</text>
                <text class="carousel-title">{{currentBrandInfo.name || currentCategoryInfo.name}} · 作品 {{index + 1}}</text>
              </view>
            </view>
          </swiper-item>
        </swiper>
      </view>

      <!-- 底部小图导航（AI 表情包不显示） -->
      <view class="carousel-thumbs" wx:if="{{!(currentCategory === 'ai_design' && currentSubcategory === 'ai_sticker')}}">
        <scroll-view 
          class="thumbs-scroll" 
          scroll-x 
          scroll-into-view="thumb-{{currentImageIndex}}"
          scroll-with-animation
        >
          <view class="thumbs-wrapper">
            <view 
              class="thumb-item {{index === currentImageIndex ? 'active' : ''}}" 
              wx:for="{{works}}" 
              wx:key="index"
              id="thumb-{{index}}"
              bindtap="onThumbTap"
              data-index="{{index}}"
            >
              <image 
                class="thumb-image" 
                src="{{item.image || item}}" 
                mode="aspectFill"
              ></image>
              <view class="thumb-indicator" wx:if="{{index === currentImageIndex}}"></view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{works.length === 0}}">
      <text class="empty-icon">🎨</text>
      <text class="empty-text">暂无作品</text>
    </view>
  </view>
</view>

<!-- 图片预览 -->
<view class="preview-modal" wx:if="{{previewVisible}}" bindtap="closePreview">
  <view class="preview-content" catchtap="stopPropagation">
    <swiper 
      class="preview-swiper" 
      current="{{previewIndex}}" 
      indicator-dots
      indicator-active-color="#ffffff"
      indicator-color="rgba(255,255,255,0.5)"
      bindchange="onPreviewChange"
    >
      <swiper-item wx:for="{{works}}" wx:key="index">
        <image 
          class="preview-image" 
          src="{{item.image || item}}" 
          mode="aspectFit"
          bindtap="closePreview"
        ></image>
      </swiper-item>
    </swiper>
    
    <view class="preview-info">
      <text class="preview-counter">{{previewIndex + 1}} / {{works.length}}</text>
      <view class="preview-actions">
        <button class="preview-btn" open-type="share">分享</button>
        <button class="preview-btn" bindtap="onSaveImage">保存</button>
      </view>
    </view>
    
    <view class="preview-close" bindtap="closePreview">✕</view>
  </view>
</view>
