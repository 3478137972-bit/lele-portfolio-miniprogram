<!--pages/portfolio/portfolio.wxml - 作品集（组件化重构版）-->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="hero-banner">
    <view class="hero-content">
      <text class="hero-title">作品集</text>
      <text class="hero-subtitle">精选设计案例展示</text>
    </view>
  </view>

  <!-- 品牌筛选器 -->
  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view 
        class="filter-item {{currentBrand === item.id ? 'active' : ''}}" 
        wx:for="{{brands}}" 
        wx:key="id"
        bindtap="onBrandTap"
        data-brand="{{item.id}}"
      >
        <text class="filter-text">{{item.name}}</text>
        <view class="filter-indicator" wx:if="{{currentBrand === item.id}}"></view>
      </view>
    </scroll-view>
  </view>

  <!-- 作品网格 -->
  <view class="works-section">
    <view class="section-header">
      <text class="section-title">{{currentBrandInfo.name}}</text>
      <text class="section-count">{{filteredWorks.length}} 张作品</text>
    </view>

    <view class="works-grid">
      <view 
        class="work-card" 
        wx:for="{{filteredWorks}}" 
        wx:key="index"
        style="animation-delay: {{index * 0.05}}s"
        bindtap="onWorkTap"
        data-index="{{index}}"
      >
        <view class="work-image-wrapper">
          <image 
            class="work-image" 
            src="{{item}}" 
            mode="aspectFill"
            lazy-load
          ></image>
          <view class="work-overlay">
            <text class="work-number">{{index + 1}}</text>
          </view>
        </view>
        <view class="work-info">
          <text class="work-brand">{{currentBrandInfo.name}}</text>
          <text class="work-index">作品 {{index + 1}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredWorks.length === 0}}">
      <text class="empty-icon">🎨</text>
      <text class="empty-text">暂无作品</text>
    </view>
  </view>
</view>

<!-- 图片预览 -->
<view class="preview-modal" wx:if="{{previewVisible}}" bindtap="closePreview">
  <view class="preview-content" catchtap="stopPropagation">
    <swiper 
      class="preview-swiper" 
      current="{{previewIndex}}" 
      indicator-dots
      indicator-active-color="#ffffff"
      indicator-color="rgba(255,255,255,0.5)"
      bindchange="onPreviewChange"
    >
      <swiper-item wx:for="{{filteredWorks}}" wx:key="*this">
        <image 
          class="preview-image" 
          src="{{item}}" 
          mode="aspectFit"
          bindtap="closePreview"
        ></image>
      </swiper-item>
    </swiper>
    
    <view class="preview-info">
      <text class="preview-counter">{{previewIndex + 1}} / {{filteredWorks.length}}</text>
      <view class="preview-actions">
        <button class="preview-btn" open-type="share">分享</button>
        <button class="preview-btn" bindtap="onSaveImage">保存</button>
      </view>
    </view>
    
    <view class="preview-close" bindtap="closePreview">✕</view>
  </view>
</view>
