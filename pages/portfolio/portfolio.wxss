/* pages/portfolio/portfolio.wxss - 作品集（组件化重构版） */

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* ===== 顶部横幅 ===== */
.hero-banner {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 60rpx 32rpx 80rpx;
  text-align: center;
}

.hero-content {
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ===== 品牌筛选器 ===== */
.filter-section {
  background: #ffffff;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.filter-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  background: #f3f4f6;
  transition: all 0.3s ease;
  position: relative;
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-item.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
}

.filter-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
  transition: color 0.3s ease;
}

.filter-item.active .filter-text {
  color: #ffffff;
}

.filter-indicator {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ffffff;
}

/* ===== 作品区块 ===== */
.works-section {
  padding: 32rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #F97316;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 作品网格 ===== */
.works-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.work-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: workSlideUp 0.6s ease-out both;
}

@keyframes workSlideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.work-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.work-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.work-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.work-card:active .work-image {
  transform: scale(1.05);
}

.work-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.3) 100%);
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  padding: 16rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.work-card:active .work-overlay {
  opacity: 1;
}

.work-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.work-info {
  padding: 20rpx;
}

.work-brand {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.work-index {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #9ca3af;
}

/* ===== 图片预览 ===== */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.preview-content {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.preview-swiper {
  flex: 1;
  width: 100%;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preview-counter {
  font-size: 26rpx;
  color: #ffffff;
}

.preview-actions {
  display: flex;
  gap: 16rpx;
}

.preview-btn {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 32rpx;
  font-size: 48rpx;
  color: #ffffff;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.preview-close:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.9);
}
