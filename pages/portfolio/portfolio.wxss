/* pages/portfolio/portfolio.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 品牌区块 */
.brand-section {
  margin-bottom: 50rpx;
}

.brand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.brand-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.brand-type {
  font-size: 26rpx;
  color: #F97316;
  background: rgba(249, 115, 22, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 图片网格 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.work-image {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 图片点击效果 */
.work-image:active {
  opacity: 0.7;
  transform: scale(0.98);
}
