/* pages/portfolio/portfolio.wxss - 案例集（三级分类重构版） */

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* ===== 顶部横幅 ===== */
.hero-banner {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 60rpx 32rpx 80rpx;
  text-align: center;
}

.hero-content {
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ===== 一级分类 ===== */
.category-section {
  background: #ffffff;
  margin: -40rpx 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.category-scroll {
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  transition: all 0.3s ease;
  position: relative;
  min-width: 120rpx;
}

.category-item:active {
  transform: scale(0.95);
}

.category-item.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.category-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.category-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #6b7280;
  white-space: nowrap;
}

.category-item.active .category-text {
  color: #ffffff;
}

.category-indicator {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: #F97316;
  border-radius: 2rpx;
  display: none;
}

.category-item.active .category-indicator {
  display: block;
}

/* ===== 二级品牌 ===== */
.brand-section {
  background: #ffffff;
  margin: 0 24rpx 16rpx !important;
  padding: 12rpx 24rpx !important;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.brand-scroll {
  white-space: nowrap;
}

.brand-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  transition: all 0.3s ease;
  position: relative;
  min-width: 100rpx;
}

.brand-item:active {
  transform: scale(0.95);
}

.brand-item.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25);
}

.brand-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
  white-space: nowrap;
}

.brand-item.active .brand-text {
  color: #ffffff;
}

.brand-indicator {
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 3rpx;
  background: #F97316;
  border-radius: 2rpx;
  display: none;
}

.brand-item.active .brand-indicator {
  display: block;
}

/* ===== 二级子分类（AI 设计作品） ===== */
.subcategory-section {
  background: #ffffff;
  margin: 0 24rpx 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

/* ===== 筛选栏（运营分类专用） ===== */
.filter-section {
  background: #ffffff;
  margin: 0 24rpx 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

/* 增长曲线入口 */
.growth-curve-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.growth-curve-entry:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 运营分类提示 */
.operations-hint {
  text-align: center;
  padding: 40rpx 24rpx;
  color: #999;
  font-size: 26rpx;
}

.operations-hint-text {
  display: block;
  color: #999;
  font-size: 26rpx;
}

.growth-curve-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.growth-curve-text {
  flex: 1;
}

.growth-curve-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.growth-curve-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.growth-curve-arrow {
  font-size: 32rpx;
  color: #fff;
  opacity: 0.8;
  margin-left: 16rpx;
}

/* 视图切换 */
.view-mode-toggle {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.view-mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.view-mode-btn:active {
  transform: scale(0.98);
}

.view-mode-btn.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25);
}

.view-mode-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.view-mode-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
}

.view-mode-btn.active .view-mode-text {
  color: #ffffff;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e5e7eb;
  transition: all 0.3s ease;
}

.search-bar:focus-within {
  border-color: #F97316;
  background: #ffffff;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1f2937;
  padding: 4rpx 0;
}

.search-input::placeholder {
  color: #9ca3af;
}

.search-icon {
  font-size: 28rpx;
  margin-left: 12rpx;
}

/* 标签筛选 */
.tag-filter-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag-filter-scroll {
  flex: 1;
}

.tag-filter-wrapper {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.tag-filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  font-size: 22rpx;
  font-weight: 500;
  color: #6b7280;
  white-space: nowrap;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.tag-filter-item:active {
  transform: scale(0.95);
}

.tag-filter-item.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.25);
}

.clear-filters {
  font-size: 22rpx;
  color: #F97316;
  font-weight: 600;
  padding: 10rpx 16rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.clear-filters:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.subcategory-scroll {
  white-space: nowrap;
}

.subcategory-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  transition: all 0.3s ease;
  position: relative;
  min-width: 100rpx;
}

.subcategory-item:active {
  transform: scale(0.95);
}

.subcategory-item.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25);
}

.subcategory-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
  white-space: nowrap;
}

.subcategory-item.active .subcategory-text {
  color: #ffffff;
}

.subcategory-indicator {
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 3rpx;
  background: #F97316;
  border-radius: 2rpx;
  display: none;
}

.subcategory-item.active .subcategory-indicator {
  display: block;
}

/* ===== 作品区块 ===== */
.works-section {
  margin: 8rpx 24rpx 0 !important;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-brand {
  font-size: 28rpx;
  font-weight: 500;
  color: #F97316;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 左右滑动画廊 ===== */
.carousel-gallery {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.carousel-main {
  width: 100%;
  /* 默认 16:9 比例：宽度 100% ≈ 704rpx（去掉 margin 48rpx），高度 = 704 × 9/16 ≈ 396rpx */
  height: 396rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  background: #ffffff;
  margin-bottom: 20rpx;
}



/* AI 表情包专用 1:1 比例 */
.carousel-main.sticker-ratio {
  /* 1:1 比例：宽度 100% ≈ 704rpx，高度 = 704rpx */
  height: 704rpx;
}

/* AI 宣传海报专用 9:16 竖版比例 */
.carousel-main.poster-ratio {
  /* 9:16 比例：宽度 100% ≈ 704rpx，高度 = 704 × 16/9 ≈ 1251rpx */
  height: 1251rpx !important;
}

/* ===== 16:9 横版轮播图（AI 小程序专用） ===== */
.carousel-main.miniprogram-ratio {
  /* 16:9 比例：宽度 100% ≈ 704rpx，高度 = 704 × 9/16 ≈ 396rpx */
  height: 396rpx !important;
}

.carousel-swiper {
  width: 100%;
  height: 100%;
}

.carousel-item {
  width: 100%;
  height: 100%;
  position: relative;
  background: #f5f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.carousel-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.carousel-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.7) 100%);
  padding: 80rpx 32rpx 32rpx;
  text-align: center;
}

.carousel-number {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.carousel-title {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 底部小图导航 */
.carousel-thumbs {
  width: 100%;
}

.thumbs-scroll {
  width: 100%;
}

.thumbs-wrapper {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.thumb-item {
  position: relative;
  width: 160rpx;
  height: 90rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.thumb-item:active {
  transform: scale(0.95);
}

.thumb-item.active {
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  border: 4rpx solid #F97316;
}

.thumb-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.thumb-indicator {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: #F97316;
}

.gallery-item {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.06),
    0 20rpx 48rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s ease;
  animation: galleryItemUp 0.6s ease-out both;
  flex: 1;
}

@keyframes galleryItemUp {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.gallery-item:active {
  transform: scale(0.98);
  box-shadow: 
    0 2rpx 8rpx rgba(0, 0, 0, 0.05),
    0 6rpx 16rpx rgba(0, 0, 0, 0.04),
    0 12rpx 32rpx rgba(0, 0, 0, 0.03);
}

/* 大图：占据 2/3 宽度 */
.gallery-item.large {
  flex: 2;
}

/* 小图：占据 1/3 宽度 */
.gallery-item.small {
  flex: 1;
}

.gallery-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  overflow: hidden;
}

.gallery-item.large .gallery-image-wrapper {
  height: 480rpx;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.gallery-item:active .gallery-overlay {
  opacity: 1;
}

.gallery-number {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.gallery-info {
  padding: 16rpx;
  text-align: center;
}

.gallery-brand {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #F97316;
  margin-bottom: 6rpx;
}

.gallery-index {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

/* ===== 时间线视图（运营分类） ===== */
.timeline-view {
  padding: 0 24rpx;
}

.timeline-group {
  margin-bottom: 40rpx;
}

.timeline-date-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.timeline-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  position: relative;
  padding-left: 16rpx;
}

.timeline-date::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  border-radius: 4rpx;
}

.timeline-count {
  font-size: 22rpx;
  color: #9ca3af;
  background: #f9fafb;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.timeline-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

/* 大屏设备：每行 4 张 */
@media (min-width: 768px) {
  .timeline-cards {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .works-grid-operations {
    grid-template-columns: repeat(4, 1fr);
  }
}

.timeline-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.06),
    0 20rpx 48rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s ease;
  animation: timelineCardUp 0.6s ease-out both;
}

@keyframes timelineCardUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.timeline-card:active {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 
    0 8rpx 20rpx rgba(0, 0, 0, 0.12),
    0 20rpx 40rpx rgba(0, 0, 0, 0.1),
    0 40rpx 80rpx rgba(0, 0, 0, 0.08),
    0 0 60rpx rgba(249, 115, 22, 0.2);
}

.timeline-card-image {
  position: relative;
  width: 100%;
  height: 280rpx;
  background: #e5e7eb;
  overflow: hidden;
}

.timeline-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.timeline-card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.timeline-card:active .timeline-card-overlay {
  opacity: 1;
}

.timeline-card-icon {
  font-size: 40rpx;
}

.timeline-card-info {
  padding: 16rpx;
}

.timeline-card-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-card-desc {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.timeline-card-tag {
  font-size: 18rpx;
  color: #F97316;
  background: rgba(249, 115, 22, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* ===== 分类网格视图（运营分类） ===== */
.grid-view {
  padding: 0 24rpx;
}

.works-grid-operations {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.work-card-operations {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.06),
    0 20rpx 48rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s ease;
  animation: workCardUp 0.6s ease-out both;
}

.work-card-operations:active {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 
    0 8rpx 20rpx rgba(0, 0, 0, 0.12),
    0 20rpx 40rpx rgba(0, 0, 0, 0.1),
    0 40rpx 80rpx rgba(0, 0, 0, 0.08),
    0 0 60rpx rgba(249, 115, 22, 0.2);
}

.work-card-operations-image {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: #e5e7eb;
  overflow: hidden;
}

.work-card-operations-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.work-card-operations-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.work-card-operations:active .work-card-operations-overlay {
  opacity: 1;
}

.work-card-operations-icon {
  font-size: 40rpx;
}

.work-card-operations-info {
  padding: 16rpx;
}

.work-card-operations-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-card-operations-desc {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-card-operations-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.work-card-operations-tag {
  font-size: 18rpx;
  color: #F97316;
  background: rgba(249, 115, 22, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* ===== 作品网格 ===== */
.works-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.work-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  /* 方案五：阴影层叠效果 */
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.06),
    0 20rpx 48rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s ease;
  animation: workCardUp 0.6s ease-out both;
}

/* stack-card-portfolio 样式覆盖（使用 !important 确保优先级） */
.work-card.stack-card-portfolio {
  border-radius: 32rpx !important;
  /* 更明显的阴影层叠效果 */
  box-shadow: 
    0 6rpx 16rpx rgba(0, 0, 0, 0.1),
    0 16rpx 36rpx rgba(0, 0, 0, 0.08),
    0 32rpx 72rpx rgba(0, 0, 0, 0.06) !important;
  transition: all 0.5s ease !important;
}

.work-card.stack-card-portfolio:active {
  transform: translateY(-4rpx) scale(1.02) !important;
  box-shadow: 
    0 8rpx 20rpx rgba(0, 0, 0, 0.12),
    0 20rpx 40rpx rgba(0, 0, 0, 0.1),
    0 40rpx 80rpx rgba(0, 0, 0, 0.08),
    0 0 60rpx rgba(249, 115, 22, 0.2) !important;
}

@keyframes workCardUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.work-card:active {
  transform: translateY(-4rpx) scale(1.02);
  /* 悬停时阴影层叠加深 */
  box-shadow: 
    0 8rpx 20rpx rgba(0, 0, 0, 0.12),
    0 20rpx 40rpx rgba(0, 0, 0, 0.1),
    0 40rpx 80rpx rgba(0, 0, 0, 0.08),
    0 0 60rpx rgba(249, 115, 22, 0.2);
}

.work-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: #e5e7eb;
}

.work-image {
  width: 100%;
  height: 100%;
}

.work-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.work-card:active .work-overlay {
  opacity: 1;
}

.work-number {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.work-info {
  padding: 20rpx;
  text-align: center;
}

.work-brand {
  display: block;
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.work-index {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* ===== 图片预览 ===== */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease-out;
}

.preview-content {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.preview-swiper {
  flex: 1;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-info {
  position: absolute;
  bottom: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.preview-counter {
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.preview-actions {
  display: flex;
  gap: 16rpx;
}

.preview-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  backdrop-filter: blur(10rpx);
}

.preview-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 32rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
  backdrop-filter: blur(10rpx);
}

.preview-close:active {
  background: rgba(255, 255, 255, 0.3);
}
