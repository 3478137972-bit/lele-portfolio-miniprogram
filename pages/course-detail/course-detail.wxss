/* ========================================
   课程详情页样式（P1 重要优化）
   优化要点：
   - 沉浸式头图
   - 底部浮动操作栏
   - 课程大纲样式升级
======================================== */

page {
  padding-bottom: 140rpx;
}

/* 课程头部 - 沉浸式头图 */
.course-header {
  position: relative;
  background: var(--primary-gradient);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl) var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-primary);
  overflow: hidden;
  transition: all var(--transition-normal);
}

.course-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30rpx); }
}

.course-header:active {
  transform: scale(0.98);
}

.course-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, #fff, transparent);
}

.header-icon {
  font-size: var(--font-size-xxxl);
  margin-right: var(--spacing-lg);
  flex-shrink: 0;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.course-name {
  font-size: var(--font-size-xxl);
  font-weight: bold;
  color: #fff;
  line-height: 1.3;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-tag {
  font-size: var(--font-size-xs);
  color: #fff;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-full);
  align-self: flex-start;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.course-tag.orange {
  background: var(--primary-gradient);
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.4);
}

.course-tag.green {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.4);
}

.course-tag.purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.4);
}

/* 课程描述 */
.course-desc {
  margin-bottom: var(--spacing-lg);
  background: #fff;
  border-left: 6rpx solid var(--primary-color);
  box-shadow: var(--shadow-md);
}

.desc-text {
  font-size: var(--font-size-lg);
  line-height: 1.8;
  color: var(--text-secondary);
  display: block;
  padding: var(--spacing-lg);
}

/* 通用区块 */
.section-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  display: block;
  text-align: center;
  position: relative;
  padding-bottom: var(--spacing-sm);
}

.section-title::after {
  content: '';
  display: block;
  width: 80rpx;
  height: 6rpx;
  background: var(--primary-gradient);
  margin: var(--spacing-xs) auto 0;
  border-radius: var(--radius-full);
}

/* 课程模块 - 升级样式 */
.modules {
  margin-bottom: var(--spacing-lg);
}

.module-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.module-item {
  background: #fff;
  padding: var(--spacing-lg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
  border: 1rpx solid var(--border-color);
}

.module-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: var(--primary-color);
  transition: all var(--transition-normal);
}

.module-item:hover {
  transform: translateX(4rpx);
  box-shadow: var(--shadow-md);
}

.module-item:hover::before {
  width: 12rpx;
}

.module-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.module-number {
  font-size: var(--font-size-xxl);
  font-weight: bold;
  color: var(--primary-color);
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  color: transparent;
}

.module-icon {
  font-size: var(--font-size-xxl);
}

.module-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--spacing-md);
}

.module-title-simple {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--spacing-md);
}

.module-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.module-point {
  font-size: var(--font-size-md);
  color: var(--text-tertiary);
  line-height: 1.8;
  display: flex;
  align-items: flex-start;
}

.module-point::before {
  content: '•';
  color: var(--primary-color);
  font-weight: bold;
  margin-right: var(--spacing-sm);
}

/* 信息区块 */
.info-section {
  margin-bottom: var(--spacing-lg);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md);
  background: #fafafa;
  border-radius: var(--radius-sm);
}

.info-label {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
  font-weight: 500;
}

.info-value {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  font-weight: 600;
}

/* 内容区块升级 */
.content-section {
  margin-bottom: var(--spacing-lg);
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.content-item {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  line-height: 1.8;
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-md);
  background: #fff;
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--border-color);
  transition: all var(--transition-normal);
}

.content-item:hover {
  border-left-color: var(--primary-color);
  transform: translateX(4rpx);
  background: #fafafa;
}

.content-item::before {
  content: '•';
  color: var(--primary-color);
  font-weight: bold;
  margin-right: var(--spacing-md);
}

/* 亮点卡片 */
.highlight {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, rgba(251, 146, 60, 0.1) 100%);
  padding: var(--spacing-lg);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-lg);
  border-left: 4rpx solid var(--primary-color);
  position: relative;
  overflow: hidden;
}

.highlight::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(249, 115, 22, 0.1) 0%, transparent 70%);
  animation: float 8s infinite;
}

.highlight-icon {
  font-size: var(--font-size-xxl);
  margin-right: var(--spacing-md);
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.highlight-text {
  font-size: var(--font-size-md);
  color: var(--primary-color);
  font-weight: 600;
  flex: 1;
  line-height: 1.6;
}

/* 特点卡片 */
.features {
  margin-bottom: var(--spacing-lg);
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.feature-item {
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-md);
  background: #fafafa;
  border-radius: var(--radius-sm);
  transition: all var(--transition-normal);
}

.feature-item:hover {
  transform: translateX(4rpx);
  background: #fff;
  box-shadow: var(--shadow-sm);
}

.feature-icon {
  font-size: var(--font-size-xl);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  color: var(--primary-color);
}

.feature-text {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* 目标卡片 */
.goal {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.15) 0%, rgba(251, 146, 60, 0.15) 100%);
  padding: var(--spacing-xl);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-lg);
  border: 2rpx solid rgba(249, 115, 22, 0.2);
  position: relative;
  overflow: hidden;
}

.goal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: var(--primary-gradient);
}

.goal-icon {
  font-size: var(--font-size-xxxl);
  margin-right: var(--spacing-lg);
}

.goal-text {
  font-size: var(--font-size-lg);
  color: var(--primary-color);
  font-weight: 600;
  flex: 1;
  line-height: 1.6;
}

/* 底部浮动操作栏 - 沉浸式升级 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  border-top: 1rpx solid rgba(229, 229, 229, 0.3);
}

/* 半透明渐变背景 */
.action-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--primary-gradient);
}

.action-bar:active {
  transform: scale(0.99);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  box-shadow: var(--shadow-primary);
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  opacity: 0;
  transition: opacity var(--transition-normal);
}

.btn-primary:active::before {
  opacity: 1;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.4);
}
