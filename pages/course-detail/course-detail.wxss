/* pages/course-detail/course-detail.wxss - 课程详情页（重新设计版） */

/* 容器 */
.container {
  min-height: 100vh;
  background: #f9fafb;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 顶部横幅 */
.hero-section {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 60rpx 32rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
  color: #ffffff;
}

.hero-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.hero-subtitle {
  font-size: 26rpx;
  opacity: 0.95;
  line-height: 1.5;
}

/* 价格卡片 */
.price-card {
  background: #ffffff;
  margin: -60rpx 24rpx 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  position: relative;
  z-index: 2;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 56rpx;
  font-weight: 700;
  color: #F97316;
}

.price-original {
  font-size: 28rpx;
  color: #9ca3af;
  text-decoration: line-through;
}

.price-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* 内容区块 */
.section {
  background: #ffffff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #F97316;
  display: inline-block;
}

/* 特性列表 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.feature-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* 课程大纲 */
.syllabus-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.syllabus-item {
  background: #f9fafb;
  padding: 24rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #F97316;
}

.syllabus-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.syllabus-number {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.syllabus-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.syllabus-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  padding-left: 60rpx;
}

/* 讲师信息 */
.instructor-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FFFFFF 100%);
  border-radius: 20rpx;
  border: 2rpx solid #FED7AA;
}

.instructor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.instructor-info {
  flex: 1;
}

.instructor-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.instructor-title {
  font-size: 24rpx;
  color: #F97316;
  margin-bottom: 12rpx;
}

.instructor-desc {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.4;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.footer-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.3s;
}

.footer-btn-primary {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(249, 115, 22, 0.3);
}

.footer-btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.35);
}

.footer-btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

.footer-btn-secondary:active {
  background: #e5e7eb;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #9ca3af;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}
