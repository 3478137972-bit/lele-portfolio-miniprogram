<!-- pages/course-detail/course-detail.wxml - 课程详情页（组件化 + 动效版） -->
<view class="container" wx:if="{{course}}">
  <!-- 顶部横幅 -->
  <view class="hero-banner" style="background: {{course.color}}">
    <view class="hero-content">
      <view class="hero-icon-wrapper" style="background: rgba(255,255,255,0.2)">
        <text class="hero-icon">{{course.icon}}</text>
      </view>
      <text class="hero-title">{{course.title}}</text>
      <text class="hero-subtitle">{{course.description}}</text>
    </view>
    <view class="hero-wave"></view>
  </view>

  <!-- 课程标签 -->
  <view class="tags-section" wx:if="{{course.tags && course.tags.length}}">
    <text 
      class="tag tag-{{course.tagType || 'default'}}" 
      wx:for="{{course.tags}}" 
      wx:key="*this"
      wx:for-item="tag"
    >{{tag}}</text>
  </view>

  <!-- 课程信息卡片 -->
  <view class="info-section">
    <view class="section-title">
      <text class="title-icon">📋</text>
      <text class="title-text">课程信息</text>
    </view>
    
    <view class="info-grid">
      <view class="info-item" wx:if="{{course.students}}">
        <text class="info-icon icon-users"></text>
        <text class="info-label">班级规模</text>
        <text class="info-value">{{course.students}}</text>
      </view>
      <view class="info-item" wx:if="{{course.duration}}">
        <text class="info-icon icon-clock"></text>
        <text class="info-label">课程周期</text>
        <text class="info-value">{{course.duration}}</text>
      </view>
      <view class="info-item" wx:if="{{course.schedule}}">
        <text class="info-icon icon-calendar"></text>
        <text class="info-label">上课时间</text>
        <text class="info-value">{{course.schedule}}</text>
      </view>
    </view>
  </view>

  <!-- 课程大纲 -->
  <view class="syllabus-section">
    <view class="section-title">
      <text class="title-icon">📚</text>
      <text class="title-text">课程大纲</text>
    </view>
    
    <view class="syllabus-list">
      <view 
        class="syllabus-item" 
        wx:for="{{course.syllabus}}" 
        wx:key="index"
        wx:for-index="index"
      >
        <view class="syllabus-number">{{index + 1}}</view>
        <view class="syllabus-content">
          <text class="syllabus-title">{{item.title}}</text>
          <text class="syllabus-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 讲师信息 -->
  <view class="instructor-section">
    <view class="section-title">
      <text class="title-icon">👨‍🏫</text>
      <text class="title-text">讲师介绍</text>
    </view>
    
    <view class="instructor-card">
      <image class="instructor-avatar" src="{{instructor.avatar}}" mode="aspectFill"></image>
      <view class="instructor-info">
        <text class="instructor-name">{{instructor.name}}</text>
        <text class="instructor-title">{{instructor.title}}</text>
        <text class="instructor-desc">{{instructor.description}}</text>
      </view>
    </view>
  </view>

  <!-- 学员评价 -->
  <view class="reviews-section" wx:if="{{reviews && reviews.length}}">
    <view class="section-title">
      <text class="title-icon">💬</text>
      <text class="title-text">学员评价</text>
    </view>
    
    <view class="reviews-list">
      <view class="review-item" wx:for="{{reviews}}" wx:key="id">
        <view class="review-header">
          <text class="review-author">{{item.author}}</text>
          <text class="review-rating">⭐⭐⭐⭐⭐</text>
        </view>
        <text class="review-content">{{item.content}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 底部操作栏 -->
<view class="footer-bar">
  <button class="footer-btn footer-btn-secondary" open-type="share">
    分享课程
  </button>
  <button class="footer-btn footer-btn-primary" bindtap="onEnrollTap">
    立即咨询
  </button>
</view>

<!-- 加载动画 -->
<view class="loading-overlay" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
</view>
