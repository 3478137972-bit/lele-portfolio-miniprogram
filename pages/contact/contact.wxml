<!-- pages/contact/contact.wxml - 联系页（重新设计版） -->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="hero-banner">
    <view class="hero-content">
      <text class="hero-title">联系我</text>
      <text class="hero-subtitle">期待与你合作</text>
    </view>
  </view>

  <!-- 个人名片 -->
  <view class="profile-card">
    <view class="profile-avatar-wrapper">
      <image 
        class="profile-avatar" 
        src="/static/images/lele-profile.jpg" 
        mode="aspectFill"
      />
    </view>
    <view class="profile-info">
      <text class="profile-name">乐乐</text>
      <text class="profile-title">AI 训练师 / 产品经理 / IP 陪跑师</text>
      <text class="profile-desc">用 AI 为设计、产品、运营赋能</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-header">
      <text class="section-title">联系方式</text>
    </view>
    
    <view class="contact-list">
      <!-- 微信 -->
      <view class="contact-item" bindtap="copyWechat">
        <view class="contact-icon-wrapper" style="background: #DCFCE7">
          <view class="contact-icon-inner" style="color: #10B981">
            <text>💬</text>
          </view>
        </view>
        <view class="contact-info">
          <text class="contact-label">微信</text>
          <text class="contact-value">{{wechat}}</text>
        </view>
        <view class="contact-action-wrapper">
          <text class="contact-action">复制</text>
          <text class="contact-arrow">→</text>
        </view>
      </view>

      <!-- 邮箱 -->
      <view class="contact-item" bindtap="copyEmail">
        <view class="contact-icon-wrapper" style="background: #FEF3C7">
          <view class="contact-icon-inner" style="color: #F59E0B">
            <text>✉️</text>
          </view>
        </view>
        <view class="contact-info">
          <text class="contact-label">邮箱</text>
          <text class="contact-value">{{email}}</text>
        </view>
        <view class="contact-action-wrapper">
          <text class="contact-action">复制</text>
          <text class="contact-arrow">→</text>
        </view>
      </view>

      <!-- 所在地 -->
      <view class="contact-item">
        <view class="contact-icon-wrapper" style="background: #FED7AA">
          <view class="contact-icon-inner" style="color: #F97316">
            <text>📍</text>
          </view>
        </view>
        <view class="contact-info">
          <text class="contact-label">所在地</text>
          <text class="contact-value">{{location}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 社交媒体 -->
  <view class="contact-section">
    <view class="section-header">
      <text class="section-title">社交媒体</text>
    </view>
    
    <view class="social-list">
      <view class="social-item">
        <view class="social-icon-wrapper" style="background: #FCE7F3">
          <view class="social-icon-inner" style="color: #EC4899">
            <text>👤</text>
          </view>
        </view>
        <view class="social-info">
          <text class="social-label">公众号</text>
          <text class="social-value">乐乐 AI 训练师</text>
        </view>
        <text class="social-arrow">→</text>
      </view>

      <view class="social-item">
        <view class="social-icon-wrapper" style="background: #FEE2E2">
          <view class="social-icon-inner" style="color: #EF4444">
            <text>📕</text>
          </view>
        </view>
        <view class="social-info">
          <text class="social-label">小红书</text>
          <text class="social-value">乐乐 AI 训练师</text>
        </view>
        <text class="social-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 二维码 -->
  <view class="contact-section">
    <view class="section-header">
      <text class="section-title">微信二维码</text>
    </view>
    
    <view class="qrcode-card">
      <image 
        class="qrcode" 
        src="/static/images/qrcode/wechat.jpg" 
        mode="aspectFill"
        bindtap="previewQrcode"
      />
      <text class="qrcode-hint">长按识别二维码添加好友</text>
    </view>
  </view>
  
  <!-- 底部留白 -->
  <view class="footer-spacer"></view>
</view>

<!-- 分享按钮 -->
<view class="share-fab" bindtap="onShareTap">
  <text class="share-icon">📤</text>
</view>
