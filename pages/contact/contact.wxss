/* pages/contact/contact.wxss - 联系页（重新设计版） */

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* ===== 顶部横幅 ===== */
.hero-banner {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 60rpx 32rpx 80rpx;
  text-align: center;
}

.hero-content {
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ===== 个人名片 ===== */
.profile-card {
  background: #ffffff;
  margin: -40rpx 24rpx 24rpx;
  padding: 48rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
  text-align: center;
}

.profile-avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-info {
  animation: slideUp 0.6s ease-out 0.2s both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.profile-title {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.profile-desc {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 联系区块 ===== */
.contact-section {
  background: #ffffff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #F97316;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

/* ===== 联系列表 ===== */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.contact-item:active {
  transform: scale(0.98);
  background: #f3f4f6;
}

.contact-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.contact-icon-inner {
  font-size: 36rpx;
  font-weight: 700;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
}

.contact-value {
  display: block;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.contact-action-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.contact-action {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
}

.contact-arrow {
  font-size: 28rpx;
  color: #F97316;
  transition: transform 0.3s ease;
}

.contact-item:active .contact-arrow {
  transform: translateX(8rpx);
}

/* ===== 社交媒体 ===== */
.social-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.social-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.social-item:active {
  transform: scale(0.98);
  background: #f3f4f6;
}

.social-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.social-icon-inner {
  font-size: 36rpx;
  font-weight: 700;
}

.social-info {
  flex: 1;
}

.social-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
}

.social-value {
  display: block;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.social-arrow {
  font-size: 28rpx;
  color: #D1D5DB;
}

/* ===== 二维码 ===== */
.qrcode-card {
  text-align: center;
  padding: 32rpx;
  background: #f9fafb;
  border-radius: 20rpx;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  background: #e5e7eb;
}

.qrcode-hint {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 底部留白 ===== */
.footer-spacer {
  height: 80rpx;
}

/* ===== 分享按钮 ===== */
.share-fab {
  position: fixed;
  bottom: 100rpx;
  right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
  animation: fabPulse 2s ease-in-out infinite;
}

@keyframes fabPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.5);
  }
}

.share-fab:active {
  transform: scale(0.95);
}

.share-icon {
  font-size: 36rpx;
}

/* ===== 图标类 ===== */
/* 注意：微信小程序不支持 ::before/::after 伪元素的 content 属性 */
/* 图标已直接在 WXML 中使用 emoji 字符 */
.icon-chat,
.icon-email,
.icon-location,
.icon-account,
.icon-book {
  /* 保留类名用于可能的样式扩展 */
  display: inline-block;
}
