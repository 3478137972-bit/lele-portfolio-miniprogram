/* pages/cases/cases.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 顶部横幅 */
.hero-banner {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 80rpx 32rpx 120rpx;
  text-align: center;
}

.hero-content {
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
}

/* 数据统计 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: -80rpx 24rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #F97316;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

/* 学员卡片区域 */
.student-section {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.student-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.student-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.student-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #F97316 0%, #FB923C 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.student-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.2);
}

.student-card:active::before {
  opacity: 1;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FED7AA 0%, #F97316 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.3);
}

.avatar-placeholder {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.student-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.student-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.student-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.student-tag.primary {
  background: linear-gradient(135deg, #FED7AA 0%, #FB923C 100%);
  color: #C2410C;
}

.student-tag.secondary {
  background: linear-gradient(135deg, #E0E7FF 0%, #A5B4FC 100%);
  color: #4338CA;
}

.student-grade {
  font-size: 22rpx;
  color: #6b7280;
}

.student-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #F97316;
  font-weight: 500;
}

.action-arrow {
  font-size: 24rpx;
  color: #F97316;
  transition: transform 0.3s ease;
}

.student-card:active .action-arrow {
  transform: translateX(4rpx);
}

/* 分类筛选 */
.filter-tabs {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-wrapper {
  display: inline-flex;
  gap: 16rpx;
}

.tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  background: #ffffff;
  font-size: 26rpx;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  border-color: transparent;
}

.filter-count {
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 案例网格 */
.case-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.case-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
}

.case-card:active {
  transform: scale(0.98);
}

.case-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  overflow: hidden;
}

.case-image {
  width: 100%;
  height: 100%;
}

.case-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.case-card:active .case-overlay {
  opacity: 1;
}

.view-icon {
  font-size: 48rpx;
}

.case-content {
  padding: 20rpx;
}

.case-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tag-web { background: #FED7AA; color: #C2410C; }
.tag-payment { background: #FED7AA; color: #C2410C; }
.tag-portfolio { background: #FED7AA; color: #C2410C; }
.tag-feedback { background: #FED7AA; color: #C2410C; }
.tag-interaction { background: #FED7AA; color: #C2410C; }

.case-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #ffffff;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 图片预览 */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.preview-modal.active {
  display: flex;
}

.preview-content {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  border: none;
  border-radius: 50%;
  font-size: 40rpx;
  line-height: 64rpx;
  text-align: center;
  z-index: 10;
}

.preview-swiper {
  flex: 1;
  display: flex;
  align-items: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-info {
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.8);
  text-align: center;
}

.preview-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.preview-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
