/* pages/cases/cases.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 40rpx 0;
  color: #ffffff;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

/* 数据统计 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* 分类筛选 */
.filter-tabs {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-wrapper {
  display: inline-flex;
  gap: 16rpx;
}

.tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  background: #ffffff;
  font-size: 26rpx;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-color: transparent;
}

.filter-count {
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 案例网格 */
.case-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.case-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
}

.case-card:active {
  transform: scale(0.98);
}

.case-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  overflow: hidden;
}

.case-image {
  width: 100%;
  height: 100%;
}

.case-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.case-card:active .case-overlay {
  opacity: 1;
}

.view-icon {
  font-size: 48rpx;
}

.case-content {
  padding: 20rpx;
}

.case-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tag-web { background: #e0e7ff; color: #4338ca; }
.tag-payment { background: #fee2e2; color: #dc2626; }
.tag-portfolio { background: #dbeafe; color: #2563eb; }
.tag-feedback { background: #d1fae5; color: #059669; }
.tag-interaction { background: #fef3c7; color: #d97706; }

.case-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #ffffff;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 图片预览 */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.preview-modal.active {
  display: flex;
}

.preview-content {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  border: none;
  border-radius: 50%;
  font-size: 40rpx;
  line-height: 64rpx;
  text-align: center;
  z-index: 10;
}

.preview-swiper {
  flex: 1;
  display: flex;
  align-items: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-info {
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.8);
  text-align: center;
}

.preview-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.preview-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
