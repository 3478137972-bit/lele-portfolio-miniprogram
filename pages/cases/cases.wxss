/* pages/cases/cases.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 顶部横幅 */
.hero-banner {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 80rpx 32rpx 60rpx;
  text-align: center;
}

.hero-content {
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
}

/* 分类筛选 */
.filter-tabs {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 24rpx 24rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-wrapper {
  display: inline-flex;
  gap: 16rpx;
}

.tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 2rpx solid #F97316;
  border-radius: 40rpx;
  background: #ffffff;
  font-size: 26rpx;
  color: #F97316;
  font-weight: 600;
  transition: all 0.3s;
}

.tab.active {
  background: #F97316;
  color: #ffffff;
  border-color: #F97316;
}

/* ===== 拍立得照片墙 ===== */
.polaroid-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
  padding: 24rpx;
  justify-content: center;
}

.polaroid-item {
  width: calc(50% - 32rpx);
  max-width: 360rpx;
  animation: polaroidFadeIn 0.6s ease-out both;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

@keyframes polaroidFadeIn {
  from {
    opacity: 0;
    transform: translateY(40rpx) rotate(0deg);
  }
  to {
    opacity: 1;
    transform: translateY(0) rotate(var(--rotation, 0deg));
  }
}

.polaroid-item:active {
  transform: scale(1.05) rotate(var(--rotation, 0deg));
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

/* 拍立得相框 */
.polaroid-frame {
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(0, 0, 0, 0.12),
    0 16rpx 48rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  transition: all 0.3s ease;
}

.polaroid-image-wrapper {
  position: relative;
  width: 100%;
  /* 1:1 比例：宽度约 336rpx（50% - 32rpx），高度也设为 336rpx */
  height: 336rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  overflow: hidden;
}

.polaroid-image {
  width: 100%;
  height: 100%;
}

.polaroid-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.polaroid-item:active .polaroid-overlay {
  opacity: 1;
}

.view-icon {
  font-size: 56rpx;
  filter: drop-shadow(0 2rpx 8rpx rgba(0, 0, 0, 0.5));
}



/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #ffffff;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 图片预览 */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.preview-modal.active {
  display: flex;
}

.preview-content {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  border: none;
  border-radius: 50%;
  font-size: 40rpx;
  line-height: 64rpx;
  text-align: center;
  z-index: 10;
}

.preview-swiper {
  flex: 1;
  display: flex;
  align-items: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-info {
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.8);
  text-align: center;
}

.preview-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.preview-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
