<!--pages/cases/cases.wxml-->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="hero-banner">
    <view class="hero-content">
      <text class="hero-title">学员案例</text>
      <text class="hero-subtitle">部分学员线下学习成果</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="filter-tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view class="tabs-wrapper">
        <view 
          class="tab {{currentFilter === 'all' ? 'active' : ''}}" 
          bindtap="onFilterTap" 
          data-filter="all"
        >
          全部
        </view>
        <view 
          class="tab {{currentFilter === 'li' ? 'active' : ''}}" 
          bindtap="onFilterTap" 
          data-filter="li"
        >
          李同学
        </view>
        <view 
          class="tab {{currentFilter === 'hao' ? 'active' : ''}}" 
          bindtap="onFilterTap" 
          data-filter="hao"
        >
          郝同学
        </view>
        <view 
          class="tab {{currentFilter === 'wang' ? 'active' : ''}}" 
          bindtap="onFilterTap" 
          data-filter="wang"
        >
          王同学
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 拍立得照片墙 -->
  <view class="polaroid-wall">
    <view 
      class="polaroid-item" 
      wx:for="{{filteredCases}}" 
      wx:key="id"
      style="transform: rotate({{item.rotate || 0}}deg); animation-delay: {{index * 0.1}}s"
      bindtap="onCaseTap"
      data-index="{{index}}"
    >
      <view class="polaroid-frame">
        <view class="polaroid-image-wrapper">
          <image 
            class="polaroid-image" 
            src="{{item.image}}" 
            mode="aspectFill"
            lazy-load
          />
          <view class="polaroid-overlay">
            <text class="view-icon">🔍</text>
          </view>
        </view>
        <view class="polaroid-label">
          <text class="polaroid-name">{{item.categoryName}}</text>
          <text class="polaroid-date">{{item.date || '学习成果'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredCases.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无案例</text>
  </view>
</view>

<!-- 图片预览 -->
<view class="preview-modal {{previewVisible ? 'active' : ''}}" bindtap="closePreview">
  <view class="preview-content" catchtap="stopPropagation">
    <button class="preview-close" bindtap="closePreview">×</button>
    <swiper 
      class="preview-swiper" 
      current="{{previewIndex}}" 
      bindchange="onSwiperChange"
      indicator-dots
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#ffffff"
    >
      <swiper-item wx:for="{{filteredCases}}" wx:key="id">
        <image 
          class="preview-image" 
          src="{{item.image}}" 
          mode="aspectFit"
        />
      </swiper-item>
    </swiper>
    <view class="preview-info">
      <text class="preview-title">{{filteredCases[previewIndex].title}}</text>
      <text class="preview-desc">{{filteredCases[previewIndex].desc}}</text>
    </view>
  </view>
</view>
