<!--pages/index/index.wxml-->
<view class="container">
  <!-- 个人形象区域 -->
  <view class="profile-section">
    <image 
      class="avatar" 
      src="/static/images/lele-profile.jpg" 
      mode="aspectFill"
      bindtap="onAvatarTap"
    />
    <view class="info">
      <text class="name">乐乐</text>
      <text class="title">平面设计师 / AI 训练师</text>
      <text class="experience">1.5 年从业经验</text>
    </view>
  </view>

  <!-- 数据背书条 -->
  <view class="data-backup card card-hover">
    <view class="backup-item">
      <text class="backup-icon">🎓</text>
      <text class="backup-text">
        <text class="backup-value">500+</text>
        学员
      </text>
    </view>
    <view class="backup-item">
      <text class="backup-icon"> satisfaction</text>
      <text class="backup-text">
        <text class="backup-value">98%</text>
        满意度
      </text>
    </view>
    <view class="backup-item">
      <text class="backup-icon">🚀</text>
      <text class="backup-text">
        <text class="backup-value">100+</text>
        课程
      </text>
    </view>
  </view>

  <!-- 一句话介绍 -->
  <view class="intro card card-hover">
    <text class="intro-text">
      一个用 AI 为设计、产品、运营赋能的 AI 训练师
    </text>
  </view>

  <!-- 核心服务 -->
  <view class="services card card-hover">
    <text class="section-title">核心服务</text>
    <view class="service-list">
      <view class="service-item">
        <text class="service-icon">🎨</text>
        <text class="service-name">品牌设计</text>
      </view>
      <view class="service-item">
        <text class="service-icon">🤖</text>
        <text class="service-name">AI 训练</text>
      </view>
      <view class="service-item">
        <text class="service-icon">📱</text>
        <text class="service-name">视觉设计</text>
      </view>
      <view class="service-item">
        <text class="service-icon">💡</text>
        <text class="service-name">创意策划</text>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="quick-actions">
    <button class="action-btn primary" open-type="share">
      分享给朋友
    </button>
    <navigator 
      url="/pages/cases/cases" 
      class="action-btn secondary"
      hover-class="navigator-hover"
      hover-stop-propagation
    >
      学员案例
    </navigator>
    <navigator 
      url="/pages/portfolio/portfolio" 
      class="action-btn secondary"
      hover-class="navigator-hover"
      hover-stop-propagation
    >
      查看作品集
    </navigator>
  </view>

  <!-- 联系方式 -->
  <view class="contact-preview card card-hover">
    <text class="section-title">联系我</text>
    <view class="contact-item">
      <text class="contact-icon">📧</text>
      <text class="contact-text">3478137972@qq.com</text>
    </view>
    <view class="contact-item">
      <text class="contact-icon">📍</text>
      <text class="contact-text">江苏镇江</text>
    </view>
    <view class="contact-item">
      <text class="contact-icon">📱</text>
      <text class="contact-text">13800138000</text>
    </view>
  </view>
</view>
