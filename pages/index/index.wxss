/* ========================================
   首页样式（P0 核心优化）
   优化要点：
   - 英雄区渐变背景
   - 服务卡片样式升级
   - 数据背书条
======================================== */

page {
  padding-bottom: 60rpx;
}

/* 个人形象区域（英雄区） */
.profile-section {
  display: flex;
  align-items: center;
  background: var(--primary-gradient);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-primary);
  position: relative;
  overflow: hidden;
}

/* 顶部装饰元素 */
.profile-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30rpx); }
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  margin-right: var(--spacing-lg);
  background-color: #fff;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
}

/* 悬浮效果 */
.avatar:hover {
  transform: scale(1.05);
  box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.4);
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.name {
  font-size: var(--font-size-xxxl);
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

.title {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.experience {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.2);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-full);
  align-self: flex-start;
  backdrop-filter: blur(10rpx);
}

/* 介绍卡片 */
.intro {
  margin-bottom: var(--spacing-lg);
  background: #fff;
  border-left: 6rpx solid var(--primary-color);
  box-shadow: var(--shadow-md);
}

.intro-text {
  font-size: var(--font-size-lg);
  line-height: 1.8;
  color: var(--text-secondary);
  text-align: center;
  display: block;
  padding: var(--spacing-lg) 0;
}

/* 服务区域 */
.services {
  margin-bottom: var(--spacing-lg);
}

.section-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
  display: block;
  text-align: center;
  position: relative;
}

/* 标题装饰线 */
.section-title::after {
  content: '';
  display: block;
  width: 80rpx;
  height: 6rpx;
  background: var(--primary-gradient);
  margin: 16rpx auto 0;
  border-radius: var(--radius-full);
}

.service-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg);
  background: #f9fafb;
  border-radius: var(--radius-md);
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
}

/* 卡片hover效果 */
.service-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--primary-gradient);
  opacity: 0;
  transition: opacity var(--transition-normal);
  z-index: 0;
}

.service-item:hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-primary);
}

.service-item:hover::before {
  opacity: 0.1;
}

.service-icon {
  font-size: var(--font-size-xxl);
  margin-bottom: var(--spacing-xs);
  z-index: 1;
}

.service-name {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  font-weight: 500;
  z-index: 1;
}

/* 快速操作 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  margin: var(--spacing-lg) 0;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--primary-gradient);
  opacity: 0;
  transition: opacity var(--transition-normal);
  z-index: 0;
}

.action-btn.primary {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-primary);
}

.action-btn.primary:hover::before {
  opacity: 1;
}

.action-btn.secondary {
  background: #fff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  box-shadow: var(--shadow-sm);
}

/* 联系方式预览 */
.contact-preview {
  margin-bottom: 0;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--divider-color);
  transition: all var(--transition-normal);
}

.contact-item:hover {
  background: #f9fafb;
  padding-left: var(--spacing-sm);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: var(--font-size-xl);
  margin-right: var(--spacing-md);
  color: var(--primary-color);
}

.contact-text {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  flex: 1;
}

/* 数据背书条（新增） */
.data-backup {
  background: linear-gradient(135deg, #fff8e1 0%, #fff3e0 100%);
  border-radius: var(--radius-md);
  padding: var(--spacing-xl) var(--spacing-lg);
  margin: var(--spacing-lg) 0;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}

.data-backup::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: var(--primary-gradient);
}

.backup-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  flex: 1;
}

.backup-icon {
  font-size: var(--font-size-xl);
}

.backup-text {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.backup-value {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--primary-color);
  margin-left: var(--spacing-xs);
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200rpx 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: var(--radius-md);
}

@keyframes skeleton-loading {
  0% { background-position: -200rpx 0; }
  100% { background-position: 200rpx 0; }
}
