/* pages/index/index.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 个人形象区域 */
.profile-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
  background-color: #fff;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.experience {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

/* 介绍卡片 */
.intro {
  margin-bottom: 30rpx;
}

.intro-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  text-align: center;
  display: block;
}

/* 服务区域 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.service-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.service-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.service-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 快速操作 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 30rpx 0;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #F97316;
  border: 2rpx solid #F97316;
}

.navigator-hover {
  opacity: 0.7;
}

/* 联系方式预览 */
.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #333;
}
