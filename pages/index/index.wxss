/* pages/index/index.wxss - 首页（重新设计版） */

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F97316 0%, #FB923C 30%, #f5f7fa 30%);
  padding-bottom: 120rpx;
}

/* ===== 顶部横幅 ===== */
.hero-banner {
  position: relative;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  animation: float 6s ease-in-out infinite;
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -40rpx;
  right: -40rpx;
  animation-delay: 0s;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  bottom: 40rpx;
  left: -30rpx;
  animation-delay: 2s;
}

.circle-3 {
  width: 80rpx;
  height: 80rpx;
  top: 60rpx;
  right: 30%;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(180deg); }
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
}

/* ===== 数据环绕头像 ===== */
.avatar-data-wrapper {
  position: relative;
  width: 320rpx;
  height: 380rpx;
  margin: 0 auto 40rpx;
  animation: scaleIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 数据徽章 */
.data-badge {
  position: absolute;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10rpx);
  animation: dataBadgeFloat 3s ease-in-out infinite;
  z-index: 10;
}

@keyframes dataBadgeFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 左上：学员 */
.data-badge.data-top-left {
  top: 20rpx;
  left: 0;
  animation-delay: 0s;
}

/* 右上：课程 */
.data-badge.data-top-right {
  top: 20rpx;
  right: 0;
  animation-delay: 1.5s;
}

.data-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #F97316;
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.3);
}

.data-label {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 4rpx;
  font-weight: 500;
}

/* 头像光环 */
.avatar-ring {
  position: absolute;
  top: 80rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 100rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

.ring-2 {
  top: 60rpx;
  left: 0;
  right: 0;
  bottom: 80rpx;
  border-width: 8rpx;
  border-color: rgba(255, 255, 255, 0.15);
  animation-delay: 0.5s;
  animation-duration: 2.5s;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.4;
  }
}

/* 头像主体 */
.avatar {
  position: absolute;
  top: 80rpx;
  left: 40rpx;
  right: 40rpx;
  bottom: 100rpx;
  width: 240rpx;
  height: 240rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 50%;
  border: 10rpx solid #ffffff;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.3);
}

.avatar-badge {
  position: absolute;
  bottom: 120rpx;
  right: 60rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 6rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.4);
  animation: badgePulse 2s ease-in-out infinite;
  z-index: 10;
}

@keyframes badgePulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.4);
  }
  50% {
    transform: scale(1.1);
    box-shadow: 0 6rpx 24rpx rgba(249, 115, 22, 0.6);
  }
}

/* 姓名标签 */
.profile-name-wrapper {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  z-index: 10;
  animation: slideUp 0.6s ease-out 0.3s both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  letter-spacing: 4rpx;
  line-height: 1.2;
}

.profile-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.name {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.title {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 8rpx;
}

.experience {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 介绍语 */
.hero-intro {
  margin-top: 24rpx;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  /* 注意：backdrop-filter 需要基础库 2.24.4+，旧版本会降级为半透明背景 */
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  animation: fadeIn 0.8s ease-out 0.4s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.intro-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.6;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 1rpx;
}

/* ===== 数据卡片 ===== */
.stats-section {
  padding: 0 24rpx;
  margin-top: -40rpx;
}

.stats-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.1);
  animation: slideUp 0.6s ease-out 0.3s both;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
  animation: numberCount 1s ease-out both;
}

@keyframes numberCount {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, #e5e7eb 50%, transparent 100%);
}

/* ===== 区块通用样式 ===== */
.services-section,
.cases-section,
.actions-section,
.contact-section {
  background: #ffffff;
  margin: 32rpx 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #F97316;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-more {
  font-size: 24rpx;
  color: #F97316;
  text-decoration: none;
}

/* ===== 服务网格 ===== */
.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.service-card {
  background: #f9fafb;
  padding: 28rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  /* 方案五：阴影层叠效果 */
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.06),
    0 20rpx 48rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s ease;
  animation: cardSlideUp 0.6s ease-out both;
}

@keyframes cardSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.service-card:active {
  transform: translateY(-4rpx) scale(1.02);
  background: #fff7ed;
  box-shadow: 
    0 8rpx 20rpx rgba(0, 0, 0, 0.12),
    0 20rpx 40rpx rgba(0, 0, 0, 0.1),
    0 40rpx 80rpx rgba(0, 0, 0, 0.08),
    0 0 60rpx rgba(249, 115, 22, 0.2);
}

.service-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  transition: transform 0.3s ease;
}

.service-card:active .service-icon-wrapper {
  transform: scale(0.9);
}

.service-icon {
  font-size: 40rpx;
  font-weight: 700;
}

.service-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.service-desc {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

/* ===== 案例预览 ===== */
.cases-preview {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.case-card {
  position: relative;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  /* 方案五：阴影层叠效果 */
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.06),
    0 20rpx 48rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s ease;
}

.case-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.case-card:active .case-image {
  transform: scale(1.05);
}

.case-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.7) 100%);
}

.case-title {
  display: block;
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ===== 快速入口 ===== */
.actions-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-card {
  position: relative;
  background: #f9fafb;
  border-radius: 20rpx;
  overflow: hidden;
  transition: all 0.3s ease;
}

.action-hover {
  transform: translateX(8rpx);
  background: #f3f4f6;
}

.action-content {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 20rpx;
}

.action-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.action-info {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.action-arrow {
  font-size: 32rpx;
  color: #F97316;
  transition: transform 0.3s ease;
}

.action-hover .action-arrow {
  transform: translateX(8rpx);
}

/* ===== 联系方式 ===== */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.contact-item:active {
  transform: scale(0.98);
  background: #f3f4f6;
}

.contact-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.contact-icon {
  font-size: 32rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.contact-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.contact-action {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
}

/* ===== 底部留白 ===== */
.footer-spacer {
  height: 80rpx;
}

/* ===== 分享按钮 ===== */
.share-fab {
  position: fixed;
  bottom: 100rpx;
  right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
  animation: fabPulse 2s ease-in-out infinite;
}

@keyframes fabPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.5);
  }
}

.share-fab:active {
  transform: scale(0.95);
}

.share-icon {
  font-size: 36rpx;
}

/* ===== 通用动画 ===== */
.navigator-hover {
  opacity: 0.7;
}
