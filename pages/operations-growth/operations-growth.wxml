<!--pages/operations-growth/operations-growth.wxml-->
<!--自媒体运营增长曲线页面 - 动态交互式图表-->
<view class="container">
  
  <!-- 顶部标题 -->
  <view class="header">
    <view class="title">📈 自媒体运营增长曲线</view>
    <view class="subtitle">从 0 到 2000 粉丝的成长之路</view>
  </view>
  
  <!-- 阶段进度卡片 -->
  <view class="stage-card">
    <view class="stage-info">
      <view class="stage-label">当前阶段</view>
      <view class="stage-value">总管阶段 {{currentStage}}</view>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{(followerData[followerData.length-1].followers / targetFollowers) * 100}}%"></view>
    </view>
    <view class="stage-stats">
      <view class="stat-item">
        <view class="stat-value">{{followerData[followerData.length-1].followers}}</view>
        <view class="stat-label">当前粉丝</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{targetFollowers}}</view>
        <view class="stat-label">目标粉丝</view>
      </view>
    </view>
  </view>
  
  <!-- 增长曲线图表 -->
  <view class="chart-container">
    <view class="chart-title">粉丝增长趋势</view>
    
    <!-- SVG 图表 -->
    <svg class="chart-svg" width="{{chartConfig.width}}" height="{{chartConfig.height}}">
      <!-- 背景网格 -->
      <defs>
        <pattern id="grid" width="50" height="50" patternUnits="userSpaceOnUse">
          <path d="M 50 0 L 0 0 0 50" fill="none" stroke="#f0f0f0" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="{{chartConfig.width}}" height="{{chartConfig.height}}" fill="url(#grid)" />
      
      <!-- 坐标轴 -->
      <line x1="{{chartConfig.padding}}" y1="{{maxY}}" x2="{{maxX}}" y2="{{maxY}}" stroke="#ddd" stroke-width="2"/>
      <line x1="{{chartConfig.padding}}" y1="{{chartConfig.padding}}" x2="{{chartConfig.padding}}" y2="{{maxY}}" stroke="#ddd" stroke-width="2"/>
      
      <!-- 增长曲线 -->
      <path d="{{chartPath}}" fill="none" stroke="{{chartConfig.lineColor}}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      
      <!-- 数据点 -->
      <g wx:for="{{chartPoints}}" wx:key="date" wx:for-index="index">
        <circle 
          class="chart-point {{selectedPoint && selectedPoint.date === item.date ? 'selected' : ''}}"
          cx="{{item.x}}" 
          cy="{{item.y}}" 
          r="{{chartConfig.pointRadius}}" 
          fill="{{selectedPoint && selectedPoint.date === item.date ? '#ff4d4f' : chartConfig.pointColor}}"
          data-index="{{index}}"
          bindtap="onPointTap"
        />
        <!-- 数据标签 -->
        <text 
          x="{{item.x}}" 
          y="{{item.y - 15}}" 
          font-size="10" 
          fill="{{chartConfig.textColor}}"
          text-anchor="middle"
        >{{item.followers}}</text>
      </g>
      
      <!-- X 轴标签（日期） -->
      <text x="{{chartConfig.padding}}" y="{{maxY + 20}}" font-size="10" fill="{{chartConfig.textColor}}">2025-09</text>
      <text x="{{maxX}}" y="{{maxY + 20}}" font-size="10" fill="{{chartConfig.textColor}}" text-anchor="end">2025-12</text>
      
      <!-- Y 轴标签 -->
      <text x="{{chartConfig.padding - 10}}" y="{{chartConfig.padding}}" font-size="10" fill="{{chartConfig.textColor}}" text-anchor="end">2000</text>
      <text x="{{chartConfig.padding - 10}}" y="{{maxY}}" font-size="10" fill="{{chartConfig.textColor}}" text-anchor="end">0</text>
    </svg>
    
    <!-- 提示文字 -->
    <view class="chart-tip">👆 点击数据点查看详情</view>
  </view>
  
  <!-- 里程碑时间轴 -->
  <view class="milestone-section">
    <view class="section-title">🏆 关键里程碑</view>
    <view class="milestone-list">
      <view class="milestone-item" wx:for="{{chartPoints}}" wx:key="date" wx:for-index="index">
        <view class="milestone-dot {{selectedPoint && selectedPoint.date === item.date ? 'active' : ''}}" data-index="{{index}}" bindtap="onPointTap"></view>
        <view class="milestone-content">
          <view class="milestone-date">{{item.date}}</view>
          <view class="milestone-info">
            <view class="milestone-label">{{item.label}}</view>
            <view class="milestone-value">{{item.followers}} 粉丝</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 详情面板（弹窗） -->
  <view class="detail-panel {{showDetail ? 'show' : ''}}" wx:if="{{showDetail}}">
    <view class="detail-overlay" bindtap="closeDetail"></view>
    <view class="detail-content">
      <view class="detail-header">
        <view class="detail-title">📊 数据详情</view>
        <view class="detail-close" bindtap="closeDetail">✕</view>
      </view>
      
      <view class="detail-body" wx:if="{{selectedPoint}}">
        <view class="detail-row">
          <view class="detail-label">日期</view>
          <view class="detail-value">{{selectedPoint.date}}</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">粉丝数</view>
          <view class="detail-value highlight">{{selectedPoint.followers}} 人</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">里程碑</view>
          <view class="detail-value">{{selectedPoint.label}}</view>
        </view>
        
        <!-- 增长数据 -->
        <view class="detail-stats">
          <view class="detail-stat">
            <view class="detail-stat-label">累计增长</view>
            <view class="detail-stat-value">+{{selectedPoint.followers}}</view>
          </view>
          <view class="detail-stat">
            <view class="detail-stat-label">完成率</view>
            <view class="detail-stat-value">{{((selectedPoint.followers / targetFollowers) * 100).toFixed(1)}}%</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
</view>
