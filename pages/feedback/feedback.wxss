/* pages/feedback/feedback.wxss - 学员反馈页（图片展示） */

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 32rpx;
}

/* ===== 顶部横幅 ===== */
.header-section {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 80rpx 32rpx 120rpx;
  text-align: center;
}

.header-content {
  color: #ffffff;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  margin-bottom: 20rpx;
}

.header-count {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  backdrop-filter: blur(10rpx);
}

/* ===== 反馈图片网格 ===== */
.feedback-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 32rpx;
  margin-top: -80rpx;
  position: relative;
}

.feedback-item {
  position: relative;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.feedback-item:active {
  transform: scale(0.98);
}

.feedback-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.feedback-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
  display: flex;
  justify-content: flex-end;
}

.feedback-index {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: rgba(249, 115, 22, 0.9);
  border-radius: 12rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbbbbb;
}

/* ===== 图片预览 ===== */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.preview-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
}

.preview-content {
  position: relative;
  z-index: 1001;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.preview-swiper {
  flex: 1;
  width: 100%;
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.preview-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preview-count {
  color: #ffffff;
  font-size: 28rpx;
}

.preview-btn {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  background: #F97316;
  color: #ffffff;
  border-radius: 40rpx;
  border: none;
}

.preview-btn::after {
  border: none;
}

/* ===== 加载状态 ===== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #F97316;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
