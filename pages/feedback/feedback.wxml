<!-- pages/feedback/feedback.wxml - 学员反馈页（图片展示） -->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="header-section">
    <view class="header-content">
      <text class="header-title">💬 学员反馈</text>
      <text class="header-subtitle">{{courseTitle}}</text>
      <text class="header-count">共 {{feedbackImages.length}} 条反馈</text>
    </view>
  </view>

  <!-- 反馈图片网格 -->
  <view class="feedback-grid" wx:if="{{feedbackImages.length > 0}}">
    <view 
      class="feedback-item" 
      wx:for="{{feedbackImages}}" 
      wx:key="*this"
      wx:for-index="index"
      bindtap="onImageTap"
      data-index="{{index}}"
    >
      <image 
        class="feedback-image" 
        src="{{item}}" 
        mode="aspectFill"
        lazy-load
      ></image>
      <view class="feedback-overlay">
        <text class="feedback-index">{{index + 1}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📷</text>
    <text class="empty-text">暂无学员反馈</text>
    <text class="empty-hint">敬请期待后续更新</text>
  </view>

  <!-- 图片预览 -->
  <view class="preview-modal" wx:if="{{showPreview}}" catchtouchmove="true">
    <view class="preview-mask" bindtap="closePreview"></view>
    <view class="preview-content">
      <swiper 
        class="preview-swiper" 
        current="{{previewIndex}}"
        bindchange="onPreviewChange"
        indicator-dots
        indicator-color="rgba(255,255,255,0.5)"
        indicator-active-color="#ffffff"
      >
        <swiper-item wx:for="{{feedbackImages}}" wx:key="*this">
          <image 
            class="preview-image" 
            src="{{item}}" 
            mode="widthFix"
            bindtap="closePreview"
          ></image>
        </swiper-item>
      </swiper>
      
      <view class="preview-bar">
        <text class="preview-count">{{previewIndex + 1}} / {{feedbackImages.length}}</text>
        <button class="preview-btn" bindtap="onSaveImage">保存</button>
      </view>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-overlay" wx:if="{{feedbackImages.length === 0 && !empty}}">
  <view class="loading-spinner"></view>
</view>
