<!--pages/about/about.wxml-->
<view class="container">
  <!-- 个人介绍 -->
  <view class="profile-card card">
    <image 
      class="avatar" 
      src="/static/images/lele-profile.jpg" 
      mode="aspectFill"
    />
    <view class="info">
      <text class="name">乐乐</text>
      <text class="title">平面设计师 / AI 训练师</text>
      <text class="location">📍 江苏镇江</text>
    </view>
  </view>

  <!-- 一句话介绍 -->
  <view class="intro card">
    <text class="intro-text">
      一个用 AI 为设计、产品、运营赋能的 AI 训练师
    </text>
  </view>

  <!-- 从业经历 -->
  <view class="experience card">
    <text class="section-title">从业经历</text>
    <view class="timeline">
      <view class="timeline-item">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <text class="timeline-title">1.5 年设计经验</text>
          <text class="timeline-desc">专注于品牌设计、视觉设计</text>
        </view>
      </view>
      <view class="timeline-item">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <text class="timeline-title">AI 训练师</text>
          <text class="timeline-desc">用 AI 赋能设计、产品、运营</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 技能标签 -->
  <view class="skills card">
    <text class="section-title">专业技能</text>
    <view class="skill-tags">
      <view class="tag">品牌设计</view>
      <view class="tag">视觉设计</view>
      <view class="tag">AI 训练</view>
      <view class="tag">创意设计</view>
      <view class="tag">产品设计</view>
      <view class="tag">运营设计</view>
      <view class="tag">AI 获客</view>
      <view class="tag">AI 内容</view>
    </view>
  </view>

  <!-- 线下活动 -->
  <view class="activities card">
    <text class="section-title">线下活动</text>
    
    <!-- 江苏大学活动 -->
    <view class="activity-item">
      <view class="activity-header">
        <text class="activity-icon">🎓</text>
        <view class="activity-info">
          <text class="activity-name">乐乐江大 AI 线下分享会</text>
          <text class="activity-location">📍 江苏大学</text>
        </view>
      </view>
      
      <view class="activity-details">
        <view class="detail-row">
          <text class="detail-label">📅 活动时间</text>
          <text class="detail-value">2025.10.31 - 12.19</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">⏰ 频率</text>
          <text class="detail-value">每周五晚 19 点</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">👥 规模</text>
          <text class="detail-value">10 人小班制</text>
        </view>
      </view>
      
      <view class="activity-content">
        <text class="content-title">分享内容</text>
        <view class="content-list">
          <view class="content-item">• 定位实战心法</view>
          <view class="content-item">• AI 结合业务打法</view>
          <view class="content-item">• AI 共创圈新思路</view>
          <view class="content-item">• AIP 打造思路</view>
          <view class="content-item">• 乐乐 AI 设计课程</view>
        </view>
      </view>
      
      <view class="activity-highlight">
        <text class="highlight-icon">💡</text>
        <text class="highlight-text">AI 时代超级个体全链路打法分享</text>
      </view>
    </view>

    <!-- 南京线下沙龙（待补充） -->
    <view class="activity-item coming-soon">
      <view class="activity-header">
        <text class="activity-icon">🏙️</text>
        <view class="activity-info">
          <text class="activity-name">南京线下沙龙</text>
          <text class="activity-status">筹备中</text>
        </view>
      </view>
      <text class="coming-text">敬请期待，即将开启</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-card card">
    <text class="section-title">联系我</text>
    <view class="contact-list">
      <view class="contact-item" bindtap="copyWechat">
        <text class="contact-icon">💬</text>
        <view class="contact-info">
          <text class="contact-label">微信</text>
          <text class="contact-value">m347820705</text>
        </view>
        <text class="contact-action">点击复制</text>
      </view>
      <view class="contact-item" bindtap="copyEmail">
        <text class="contact-icon">📧</text>
        <view class="contact-info">
          <text class="contact-label">邮箱</text>
          <text class="contact-value">3478137972@qq.com</text>
        </view>
        <text class="contact-action">点击复制</text>
      </view>
    </view>
  </view>
</view>
