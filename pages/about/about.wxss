/* pages/about/about.wxss - 关于页（重新设计版） */

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* ===== 顶部横幅 ===== */
.hero-banner {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  padding: 60rpx 32rpx 80rpx;
  text-align: center;
}

.hero-content {
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ===== 个人名片 ===== */
.profile-card {
  background: #ffffff;
  margin: -40rpx 24rpx 24rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
  text-align: center;
}

.profile-avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-info {
  animation: slideUp 0.6s ease-out 0.2s both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.profile-title {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 20rpx;
}

.profile-meta {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
  color: #9ca3af;
}

.meta-text {
  font-size: 24rpx;
  color: #6b7280;
}

/* ===== 通用区块 ===== */
.section {
  background: #ffffff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #F97316;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

/* ===== 时间轴 ===== */
.timeline {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  position: relative;
}

.timeline-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.3);
  z-index: 2;
}

.timeline-line {
  flex: 1;
  width: 4rpx;
  background: #e5e7eb;
  min-height: 40rpx;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-content {
  flex: 1;
  padding-top: 4rpx;
}

.timeline-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.timeline-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

/* ===== 技能网格 ===== */
.skill-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.skill-tag {
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.25);
  animation: skillPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55) both;
  animation-delay: var(--animation-delay, 0s);
}

@keyframes skillPop {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.skill-tag:active {
  transform: scale(0.95);
}

/* ===== 活动卡片 ===== */
.activity-card {
  background: #f9fafb;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.activity-card:active {
  transform: scale(0.98);
}

.activity-cover {
  width: 100%;
  height: 240rpx;
  background: #e5e7eb;
}

.activity-body {
  padding: 24rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.activity-info {
  flex: 1;
}

.activity-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.activity-sub {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.activity-badge {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.25);
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-icon {
  font-size: 24rpx;
  color: #9ca3af;
}

.meta-text {
  font-size: 24rpx;
  color: #6b7280;
}

.activity-content {
  margin-bottom: 20rpx;
}

.content-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.content-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.content-tag {
  padding: 8rpx 16rpx;
  background: #ffffff;
  color: #6b7280;
  font-size: 22rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
}

.activity-highlight {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FFFFFF 100%);
  border-radius: 16rpx;
  border: 2rpx solid #FED7AA;
  margin-bottom: 20rpx;
}

.highlight-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.highlight-icon {
  font-size: 24rpx;
}

.highlight-text {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
  flex: 1;
}

.activity-photos {
  margin-top: 20rpx;
}

.photos-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.photo-wall {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  width: 100%;
  height: 160rpx;
  border-radius: 12rpx;
  background: #e5e7eb;
}

/* ===== 即将到来的活动 ===== */
.coming-soon {
  background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
  border: 2rpx dashed #D1D5DB;
}

.coming-content {
  padding: 60rpx 32rpx;
  text-align: center;
}

.coming-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coming-icon {
  font-size: 40rpx;
}

.coming-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.coming-status {
  display: block;
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.coming-desc {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

/* ===== 联系方式 ===== */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.contact-item:active {
  transform: scale(0.98);
  background: #f3f4f6;
}

.contact-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.contact-icon {
  font-size: 32rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.contact-value {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.contact-action {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 600;
}

/* ===== 底部留白 ===== */
.footer-spacer {
  height: 40rpx;
}
