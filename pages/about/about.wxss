/* pages/about/about.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 个人卡片 */
.profile-card {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
}

.profile-card .avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
  background-color: #fff;
}

.profile-card .info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-card .name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.profile-card .title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.profile-card .location {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 介绍卡片 */
.intro {
  margin-bottom: 30rpx;
}

.intro-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  text-align: center;
  display: block;
}

/* 时间线 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.timeline {
  position: relative;
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  margin-bottom: 40rpx;
  position: relative;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #F97316;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  top: 8rpx;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
}

/* 技能标签 */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.contact-action {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 500;
}
