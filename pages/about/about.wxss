/* pages/about/about.wxss - 关于页样式 */
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 个人卡片 */
.profile-card {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
}

.profile-card .avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
  background-color: #fff;
}

.profile-card .info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-card .name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.profile-card .title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.profile-card .location {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 介绍卡片 */
.intro {
  margin-bottom: 30rpx;
}

.intro-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  text-align: center;
  display: block;
}

/* 时间线 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.timeline {
  position: relative;
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  margin-bottom: 40rpx;
  position: relative;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #F97316;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  top: 8rpx;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
}

/* 技能标签 */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* ========== 线下活动 - 重新设计 ========== */
.activities {
  margin-bottom: 30rpx;
}

/* 活动卡片 */
.activity-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.activity-card:last-child {
  margin-bottom: 0;
}

/* 活动头图 */
.activity-cover {
  width: 100%;
  height: 320rpx;
  background-color: #f0f0f0;
}

/* 活动主体 */
.activity-body {
  padding: 30rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.activity-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.activity-sub {
  font-size: 26rpx;
  color: #666;
}

.activity-badge {
  font-size: 24rpx;
  color: #F97316;
  background: rgba(249, 115, 22, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 活动元信息 */
.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 28rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #666;
}

/* 分享内容 */
.activity-content {
  margin-bottom: 24rpx;
}

.content-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
}

.content-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.content-tag {
  font-size: 24rpx;
  color: #333;
  background: #f9fafb;
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
}

/* 亮点 */
.activity-highlight {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, rgba(251, 146, 60, 0.1) 100%);
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #F97316;
  margin-bottom: 24rpx;
}

.highlight-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.highlight-text {
  font-size: 26rpx;
  color: #F97316;
  font-weight: 500;
  flex: 1;
  line-height: 1.5;
}

/* 照片墙 */
.activity-photos {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.photos-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 16rpx;
}

.photo-wall {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  background-color: #f0f0f0;
}

/* 待补充活动 */
.coming-soon {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.05) 0%, rgba(251, 146, 60, 0.05) 100%);
}

.coming-content {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.coming-icon {
  font-size: 64rpx;
}

.coming-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.coming-status {
  font-size: 24rpx;
  color: #F97316;
  background: rgba(249, 115, 22, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.coming-desc {
  font-size: 26rpx;
  color: #999;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.contact-action {
  font-size: 24rpx;
  color: #F97316;
  font-weight: 500;
}
