/* pages/operations-growth/operations-growth.wxss */
/* 自媒体运营增长曲线页面样式 */

.container {
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 32rpx 0;
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 阶段进度卡片 */
.stage-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.stage-info {
  margin-bottom: 20rpx;
}

.stage-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stage-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #36cfc9);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.stage-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

/* 图表容器 */
.chart-container {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.chart-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.chart-svg {
  width: 100%;
  display: block;
}

.chart-point {
  cursor: pointer;
  transition: all 0.3s ease;
}

.chart-point.selected {
  r: 10;
}

.chart-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 里程碑时间轴 */
.milestone-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.milestone-list {
  position: relative;
}

.milestone-list::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: #e8e8e8;
  border-radius: 2rpx;
}

.milestone-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  position: relative;
  padding-left: 64rpx;
}

.milestone-dot {
  position: absolute;
  left: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #e8e8e8;
  z-index: 1;
  transition: all 0.3s ease;
}

.milestone-dot.active {
  border-color: #1890ff;
  background: #1890ff;
  transform: scale(1.2);
}

.milestone-content {
  flex: 1;
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 20rpx;
}

.milestone-date {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.milestone-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.milestone-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.milestone-value {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 详情面板 */
.detail-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.detail-panel.show {
  opacity: 1;
  visibility: visible;
}

.detail-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.detail-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.detail-panel.show .detail-content {
  transform: translateY(0);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
}

.detail-body {
  padding-bottom: 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.detail-value.highlight {
  color: #1890ff;
  font-weight: bold;
  font-size: 32rpx;
}

.detail-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 32rpx;
  padding-top: 32rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
}

.detail-stat {
  text-align: center;
}

.detail-stat-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}
