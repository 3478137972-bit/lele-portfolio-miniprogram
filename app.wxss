/* ========================================
   乐乐小程序设计系统（Design System）
  Theme: AI 训练师个人品牌
   Brand Color: #F97316（橙色）
======================================== */

:root {
  /* ===== 色彩系统 ===== */
  --primary-color: #F97316;
  --primary-dark: #EA580C;
  --primary-light: #FB923C;
  --primary-gradient: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  
  --background-color: #F9FAFB;
  --page-bg: #F5F5F5;
  
  --text-primary: #1A1A1A;
  --text-secondary: #333333;
  --text-tertiary: #666666;
  --text-disabled: #999999;
  
  --border-color: #E5E5E5;
  --divider-color: #F0F0F0;
  
  /* ===== 间距系统 ===== */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 30rpx;
  --spacing-xl: 40rpx;
  --spacing-xxl: 60rpx;
  
  /* ===== 圆角系统 ===== */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 50rpx;
  
  /* ===== 阴影系统 ===== */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  --shadow-primary: 0 8rpx 24rpx rgba(249, 115, 22, 0.25);
  
  /* ===== 动画系统 ===== */
  --transition-fast: 0.15s;
  --transition-normal: 0.3s;
  --transition-slow: 0.5s;
  
  /* ===== 字体系统 ===== */
  --font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  --font-size-xs: 24rpx;
  --font-size-sm: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 40rpx;
  --font-size-xxxl: 44rpx;
}

/* page 通用样式 */
page {
  background-color: var(--page-bg);
  font-family: var(--font-family);
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  line-height: 1.6;
  -webkit-tap-highlight-color: transparent;
}

/* ========================================
   通用工具类（Utility Classes）
======================================== */

/* 品牌色工具类 */
.primary-color {
  color: var(--primary-color);
}

.primary-bg {
  background-color: var(--primary-color);
}

.primary-gradient {
  background: var(--primary-gradient);
}

/* 文字颜色工具类 */
.text-primary {
  color: var(--text-primary) !important;
}

.text-secondary {
  color: var(--text-secondary) !important;
}

.text-tertiary {
  color: var(--text-tertiary) !important;
}

.text-disabled {
  color: var(--text-disabled) !important;
}

/* 边框圆角工具类 */
.rounded-xs {
  border-radius: var(--radius-xs);
}

.rounded-sm {
  border-radius: var(--radius-sm);
}

.rounded-md {
  border-radius: var(--radius-md);
}

.rounded-lg {
  border-radius: var(--radius-lg);
}

.rounded-full {
  border-radius: var(--radius-full);
}

/* 阴影工具类 */
.shadow-sm {
  box-shadow: var(--shadow-sm);
}

.shadow-md {
  box-shadow: var(--shadow-md);
}

.shadow-lg {
  box-shadow: var(--shadow-lg);
}

.shadow-primary {
  box-shadow: var(--shadow-primary);
}

/* 动画工具类 */
.transition-normal {
  transition: all var(--transition-normal);
}

.transition-fast {
  transition: all var(--transition-fast);
}

/* 间距工具类 */
.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

.py-xs { padding-top: var(--spacing-xs); padding-bottom: var(--spacing-xs); }
.py-sm { padding-top: var(--spacing-sm); padding-bottom: var(--spacing-sm); }
.py-md { padding-top: var(--spacing-md); padding-bottom: var(--spacing-md); }
.py-lg { padding-top: var(--spacing-lg); padding-bottom: var(--spacing-lg); }

/* 容器工具类 */
.container {
  padding: var(--spacing-lg);
  padding-bottom: var(--spacing-xxl);
}

/* 图片工具类 */
.image-round {
  border-radius: var(--radius-md);
}

.image-circle {
  border-radius: 50%;
}

/* 按钮工具类 */
.btn-primary {
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
}

.btn-secondary {
  background: #fff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
}

/* 标题工具类 */
.page-title {
  font-size: var(--font-size-xxl);
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.page-subtitle {
  font-size: var(--font-size-md);
  color: var(--text-tertiary);
  margin-bottom: var(--spacing-lg);
}

.card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-md);
}

/* 卡片标题 */
.card-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  display: block;
  text-align: center;
}

/* 链接导航器 */
.navigator-hover {
  opacity: 0.7;
}

/* 模糊效果 */
.blur-bg {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200rpx 100%;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% { background-position: -200rpx 0; }
  100% { background-position: 200rpx 0; }
}

/* 品牌色 */
.primary-color {
  color: #F97316;
}

.primary-bg {
  background-color: #F97316;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #F97316 0%, #fb923c 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 标题 */
.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 图片 */
.image-round {
  border-radius: 16rpx;
}
